@model WebNangCao.Models.ViewModels.Admin.UserListVM
@{
    ViewData["Title"] = "Chi tiết người dùng";
    ViewData["Subtitle"] = Model.FullName;
}

<div class="row">
    <div class="col-md-8 col-xl-6">
        <div class="card user-card">
            <div class="card-block">
                <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
                    <div class="bg-primary d-flex align-items-center justify-content-center rounded-circle mr-3" style="width: 60px; height: 60px;">
                        <i class="feather icon-user text-white f-28"></i>
                    </div>
                    <div>
                        <h4 class="mb-1">@Model.FullName</h4>
                        <p class="mb-1 text-muted">@Model.Email</p>
                        <div>
                            @foreach (var role in Model.Roles)
                            {
                                var badgeClass = role == "Admin" ? "badge-primary" : role == "Staff" ? "badge-warning" : "badge-success";
                                <span class="badge @badgeClass mr-1">@role</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-sm-4 text-muted text-uppercase f-12 font-weight-bold">📞 Điện thoại</div>
                    <div class="col-sm-8 font-weight-bold">@(Model.PhoneNumber ?? "Chưa cập nhật")</div>
                </div>
                
                <div class="row mb-3">
                    <div class="col-sm-4 text-muted text-uppercase f-12 font-weight-bold">🪪 CCCD/CMND</div>
                    <div class="col-sm-8 font-weight-bold">@(Model.IdentityCardNumber ?? "Chưa cập nhật")</div>
                </div>

                <div class="row mb-3">
                    <div class="col-sm-4 text-muted text-uppercase f-12 font-weight-bold">🎂 Ngày sinh</div>
                    <div class="col-sm-8 font-weight-bold">
                        @(Model.DateOfBirth.HasValue ? Model.DateOfBirth.Value.ToString("dd/MM/yyyy") : "Chưa cập nhật")
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-sm-4 text-muted text-uppercase f-12 font-weight-bold">📊 Trạng thái</div>
                    <div class="col-sm-8">
                        @if (Model.IsActive)
                        {
                            <span class="badge badge-light-success"><i class="feather icon-check-circle"></i> Đang hoạt động</span>
                        }
                        else
                        {
                            <span class="badge badge-light-danger"><i class="feather icon-slash"></i> Đã bị khóa</span>
                        }
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-sm-4 text-muted text-uppercase f-12 font-weight-bold">🆔 User ID</div>
                    <div class="col-sm-8"><small class="text-muted">@Model.Id</small></div>
                </div>

                <div class="mt-4 pt-3 border-top">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning text-dark"><i class="feather icon-edit"></i> Chỉnh sửa</a>
                    <a asp-action="Index" class="btn btn-light"><i class="feather icon-arrow-left"></i> Quay lại</a>
                </div>
            </div>
        </div>
    </div>
</div>
