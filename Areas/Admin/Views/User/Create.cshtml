@model WebNangCao.Models.ViewModels.Admin.CreateUserVM
@{
    ViewData["Title"] = "Thêm người dùng mới";
    ViewData["Subtitle"] = "Tạo tài khoản mới trong hệ thống";
    var allRoles = ViewBag.AllRoles as List<string> ?? new List<string>();
}

<div class="row">
    <div class="col-sm-12">
        <div class="card">
            <div class="card-header">
                <h5>Thông tin tài khoản</h5>
            </div>
            <div class="card-body">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        <div asp-validation-summary="ModelOnly" class="mb-0"></div>
                    </div>
                }

                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <h6 class="mb-3"><i class="feather icon-user"></i> Thông tin cá nhân</h6>
                    <hr>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="FullName" class="form-label">Họ và tên <span class="text-danger">*</span></label>
                                <input asp-for="FullName" class="form-control" placeholder="Nguyễn Văn A" />
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Email" class="form-label">Email <span class="text-danger">*</span></label>
                                <input asp-for="Email" class="form-control" placeholder="email@example.com" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="PhoneNumber" class="form-label">Số điện thoại</label>
                                <input asp-for="PhoneNumber" class="form-control" placeholder="0901234567" />
                                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="DateOfBirth" class="form-label">Ngày sinh</label>
                                <input asp-for="DateOfBirth" class="form-control" type="date" />
                                <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class="form-group">
                                <label asp-for="IdentityCardNumber" class="form-label">Số CCCD/CMND</label>
                                <input asp-for="IdentityCardNumber" class="form-control" placeholder="001234567890" />
                                <span asp-validation-for="IdentityCardNumber" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <h6 class="mb-3 mt-4"><i class="feather icon-lock"></i> Đăng nhập & Phân quyền</h6>
                    <hr>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Password" class="form-label">Mật khẩu <span class="text-danger">*</span></label>
                                <input asp-for="Password" class="form-control" placeholder="••••••••" />
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="ConfirmPassword" class="form-label">Xác nhận mật khẩu <span class="text-danger">*</span></label>
                                <input asp-for="ConfirmPassword" class="form-control" placeholder="••••••••" />
                                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Role" class="form-label">Vai trò <span class="text-danger">*</span></label>
                                <select asp-for="Role" class="form-control">
                                    @foreach (var role in allRoles)
                                    {
                                        <option value="@role">@role</option>
                                    }
                                </select>
                                <span asp-validation-for="Role" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6 d-flex align-items-center">
                            <div class="form-group mb-0">
                                <div class="checkbox checkbox-primary checkbox-fill d-inline">
                                    <input type="checkbox" asp-for="IsActive" id="isActive" checked="">
                                    <label for="isActive" class="cr">Kích hoạt tài khoản ngay</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary"><i class="feather icon-check-circle"></i> Tạo tài khoản</button>
                        <a asp-action="Index" class="btn btn-light"><i class="feather icon-arrow-left"></i> Quay lại</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
