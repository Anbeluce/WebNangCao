@model WebNangCao.Models.ViewModels.Admin.EditUserVM
@{
    ViewData["Title"] = "Chỉnh sửa người dùng";
    ViewData["Subtitle"] = "Cập nhật thông tin tài khoản";
    var allRoles = ViewBag.AllRoles as List<string> ?? new List<string>();
}

<div class="row">
    <div class="col-sm-12">
        <div class="card">
            <div class="card-header">
                <h5>Cập nhật thông tin</h5>
            </div>
            <div class="card-body">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        <div asp-validation-summary="ModelOnly" class="mb-0"></div>
                    </div>
                }

                <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <h6 class="mb-3"><i class="feather icon-user"></i> Thông tin cá nhân</h6>
                    <hr>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="FullName" class="form-label">Họ và tên <span class="text-danger">*</span></label>
                                <input asp-for="FullName" class="form-control" />
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Email" class="form-label">Email <span class="text-danger">*</span></label>
                                <input asp-for="Email" class="form-control" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="PhoneNumber" class="form-label">Số điện thoại</label>
                                <input asp-for="PhoneNumber" class="form-control" />
                                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="DateOfBirth" class="form-label">Ngày sinh</label>
                                <input asp-for="DateOfBirth" class="form-control" type="date" />
                                <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class="form-group">
                                <label asp-for="IdentityCardNumber" class="form-label">Số CCCD/CMND</label>
                                <input asp-for="IdentityCardNumber" class="form-control" />
                                <span asp-validation-for="IdentityCardNumber" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <h6 class="mb-3 mt-4"><i class="feather icon-shield"></i> Phân quyền & Trạng thái</h6>
                    <hr>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Role" class="form-label">Vai trò <span class="text-danger">*</span></label>
                                <select asp-for="Role" class="form-control">
                                    @foreach (var role in allRoles)
                                    {
                                        <option value="@role">@role</option>
                                    }
                                </select>
                                <span asp-validation-for="Role" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6 d-flex align-items-center">
                            <div class="form-group mb-0">
                                <div class="checkbox checkbox-primary checkbox-fill d-inline">
                                    <input type="checkbox" asp-for="IsActive" id="isActive">
                                    <label for="isActive" class="cr">Tài khoản đang hoạt động</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <h6 class="mb-3 mt-4"><i class="feather icon-lock"></i> Đổi mật khẩu <small class="text-muted">(tùy chọn)</small></h6>
                    <hr>
                    <div class="alert alert-warning">
                        <i class="feather icon-info"></i> Để trống nếu bạn không muốn thay đổi mật khẩu
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="NewPassword" class="form-label">Mật khẩu mới</label>
                                <input asp-for="NewPassword" class="form-control" placeholder="••••••••" />
                                <span asp-validation-for="NewPassword" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="ConfirmNewPassword" class="form-label">Xác nhận mật khẩu mới</label>
                                <input asp-for="ConfirmNewPassword" class="form-control" placeholder="••••••••" />
                                <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-warning text-dark"><i class="feather icon-save"></i> Lưu thay đổi</button>
                        <a asp-action="Index" class="btn btn-light"><i class="feather icon-arrow-left"></i> Hủy bỏ</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
