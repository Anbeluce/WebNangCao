@model IEnumerable<WebNangCao.Models.ViewModels.Admin.UserListVM>
@{
    ViewData["Title"] = "Quản lý người dùng";
    ViewData["Subtitle"] = "Danh sách tất cả tài khoản trong hệ thống";
    var allRoles = ViewBag.AllRoles as List<string> ?? new List<string>();
}

<!-- Custom CSS for Datatables is loaded in layout if needed, but we can rely on standard bootstrap table for now or include the datatable CSS from theme -->
@section Styles {
    <!-- data tables css -->
    <link rel="stylesheet" href="~/plugins/data-tables/css/datatables.min.css">
}

<div class="row">
    <!-- Zero config table start -->
    <div class="col-sm-12">
        <div class="card">
            <div class="card-header border-bottom">
                <div class="d-flex align-items-center justify-content-between">
                    <h5>Danh sách người dùng</h5>
                    <a asp-area="Admin" asp-controller="User" asp-action="Create" class="btn btn-primary btn-sm">
                        <i class="feather icon-plus"></i> Thêm người dùng
                    </a>
                </div>
            </div>
            <div class="card-body">
                <!-- Filter form -->
                <form method="get" asp-action="Index" class="mb-4">
                    <div class="row align-items-end">
                        <div class="col-md-4 mb-2">
                            <label class="form-label">Tìm kiếm</label>
                            <input type="text" name="search" class="form-control" placeholder="Tên, email, SĐT..." value="@ViewBag.Search" />
                        </div>
                        <div class="col-md-3 mb-2">
                            <label class="form-label">Vai trò</label>
                            <select name="roleFilter" class="form-control">
                                <option value="">Tất cả</option>
                                @foreach (var role in allRoles)
                                {
                                    <option value="@role" selected="@(ViewBag.RoleFilter == role)">@role</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3 mb-2">
                            <label class="form-label">Trạng thái</label>
                            <select name="activeFilter" class="form-control">
                                <option value="">Tất cả</option>
                                <option value="true" selected="@(ViewBag.ActiveFilter == true)">Hoạt động</option>
                                <option value="false" selected="@(ViewBag.ActiveFilter == false)">Đã khóa</option>
                            </select>
                        </div>
                        <div class="col-md-2 mb-2">
                            <button type="submit" class="btn btn-info btn-block"><i class="feather icon-filter"></i> Lọc</button>
                        </div>
                    </div>
                </form>

                <div class="dt-responsive table-responsive">
                    <table id="simpletable" class="table table-striped table-bordered nowrap">
                        <thead>
                            <tr>
                                <th>Người dùng</th>
                                <th>Email</th>
                                <th>Điện thoại</th>
                                <th>Vai trò</th>
                                <th>Trạng thái</th>
                                <th>Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="d-inline-block align-middle">
                                            <div class="d-inline-block">
                                                <h6 class="m-b-0">@user.FullName</h6>
                                                @if (user.IdentityCardNumber != null)
                                                {
                                                    <p class="m-b-0 text-muted">CCCD: @user.IdentityCardNumber</p>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td>@user.Email</td>
                                    <td>@(user.PhoneNumber ?? "—")</td>
                                    <td>
                                        @foreach (var role in user.Roles)
                                        {
                                            var badgeClass = role == "Admin" ? "badge-primary" : role == "Staff" ? "badge-warning" : "badge-success";
                                            <span class="badge @badgeClass mr-1">@role</span>
                                        }
                                    </td>
                                    <td>
                                        @if (user.IsActive)
                                        {
                                            <span class="badge badge-light-success">Hoạt động</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-light-danger">Đã khóa</span>
                                        }
                                    </td>
                                    <td>
                                        <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-icon btn-outline-info btn-sm" title="Xem chi tiết">
                                            <i class="feather icon-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-icon btn-outline-warning btn-sm" title="Chỉnh sửa">
                                            <i class="feather icon-edit"></i>
                                        </a>

                                        <form asp-action="ToggleActive" asp-route-id="@user.Id" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-icon btn-outline-@(user.IsActive ? "danger" : "success") btn-sm"
                                                    title="@(user.IsActive ? "Khóa tài khoản" : "Mở khóa tài khoản")"
                                                    onclick="return confirm('@(user.IsActive ? "Bạn có chắc muốn khóa tài khoản này?" : "Bạn có chắc muốn mở khóa tài khoản này?")')">
                                                <i class="feather @(user.IsActive ? "icon-lock" : "icon-unlock")"></i>
                                            </button>
                                        </form>

                                        <form asp-action="Delete" asp-route-id="@user.Id" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-icon btn-outline-danger btn-sm" title="Xóa"
                                                    onclick="return confirm('Bạn có chắc muốn XÓA tài khoản @user.FullName? Hành động này không thể hoàn tác!')">
                                                <i class="feather icon-trash-2"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <!-- Zero config table end -->
</div>

@section Scripts {
    <!-- datatable Js -->
    <script src="~/plugins/data-tables/js/datatables.min.js"></script>
    <script>
        $(document).ready(function() {
            $('#simpletable').DataTable({
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.10.24/i18n/Vietnamese.json"
                },
                "pageLength": 10,
                "ordering": false // Disable datatables sorting to not mess with backend sorting if any, or keep true
            });
        });
    </script>
}
