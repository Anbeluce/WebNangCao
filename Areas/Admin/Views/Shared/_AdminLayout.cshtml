<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=0, minimal-ui">
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <title>@ViewData["Title"] - Admin | Chung cư Smart</title>

    <!-- Favicon icon -->
    <link rel="icon" href="~/images/favicon.ico" type="image/x-icon">
    <!-- fontawesome icon -->
    <link rel="stylesheet" href="~/fonts/fontawesome/css/fontawesome-all.min.css">
    <!-- animation css -->
    <link rel="stylesheet" href="~/plugins/animation/css/animate.min.css">
    <!-- vendor css -->
    <link rel="stylesheet" href="~/css/style.css">
    
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body { font-family: 'Inter', sans-serif !important; }
        /* Fix validation error color */
        .field-validation-error { color: #dc3545; font-size: 80%; mt-1; }
        .input-validation-error { border-color: #dc3545; }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
    <!-- [ Pre-loader ] start -->
    <div class="loader-bg">
        <div class="loader-track">
            <div class="loader-fill"></div>
        </div>
    </div>
    <!-- [ Pre-loader ] End -->

    <!-- [ navigation menu ] start -->
    <nav class="pcoded-navbar menupos-fixed">
        <div class="navbar-wrapper">
            <div class="navbar-brand header-logo">
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="b-brand">
                    <div class="b-bg">
                        <i class="feather icon-briefcase"></i>
                    </div>
                    <span class="b-title">Admin Panel</span>
                </a>
                <a class="mobile-menu" id="mobile-collapse" href="#!"><span></span></a>
            </div>
            <div class="navbar-content scroll-div">
                <ul class="nav pcoded-inner-navbar">
                    <li class="nav-item pcoded-menu-caption">
                        <label>Tổng quan</label>
                    </li>
                    <li class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                        <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="nav-link">
                            <span class="pcoded-micon"><i class="feather icon-home"></i></span>
                            <span class="pcoded-mtext">Dashboard</span>
                        </a>
                    </li>

                    <li class="nav-item pcoded-menu-caption">
                        <label>Quản lý</label>
                    </li>
                    <li class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "User" ? "active" : "")">
                        <a asp-area="Admin" asp-controller="User" asp-action="Index" class="nav-link">
                            <span class="pcoded-micon"><i class="feather icon-users"></i></span>
                            <span class="pcoded-mtext">Người dùng</span>
                        </a>
                    </li>
                    <li class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Apartment" ? "active" : "")">
                        <a asp-area="Admin" asp-controller="Apartment" asp-action="Index" class="nav-link">
                            <span class="pcoded-micon"><i class="feather icon-layout"></i></span>
                            <span class="pcoded-mtext">Căn hộ</span>
                        </a>
                    </li>
                    <li class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Invoice" ? "active" : "")">
                        <a asp-area="Admin" asp-controller="Invoice" asp-action="Index" class="nav-link">
                            <span class="pcoded-micon"><i class="feather icon-file-text"></i></span>
                            <span class="pcoded-mtext">Hóa đơn</span>
                        </a>
                    </li>
                    <li class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Utility" ? "active" : "")">
                        <a asp-area="Admin" asp-controller="Utility" asp-action="Index" class="nav-link">
                            <span class="pcoded-micon"><i class="feather icon-zap"></i></span>
                            <span class="pcoded-mtext">Tiện ích</span>
                        </a>
                    </li>
                    <li class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "BlogPost" ? "active" : "")">
                        <a asp-area="Admin" asp-controller="BlogPost" asp-action="Index" class="nav-link">
                            <span class="pcoded-micon"><i class="feather icon-edit-1"></i></span>
                            <span class="pcoded-mtext">Bài viết</span>
                        </a>
                    </li>

                    <li class="nav-item pcoded-menu-caption">
                        <label>Hệ thống</label>
                    </li>
                    <li class="nav-item">
                        <a asp-area="" asp-controller="Home" asp-action="Index" class="nav-link">
                            <span class="pcoded-micon"><i class="feather icon-globe"></i></span>
                            <span class="pcoded-mtext">Trang chủ web</span>
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
    <!-- [ navigation menu ] end -->

    <!-- [ Header ] start -->
    <header class="navbar pcoded-header navbar-expand-lg navbar-light">
        <div class="m-header">
            <a class="mobile-menu" id="mobile-collapse1" href="#!"><span></span></a>
            <a href="#!" class="b-brand">
                <div class="b-bg">
                    <i class="feather icon-briefcase"></i>
                </div>
                <span class="b-title">Admin Panel</span>
            </a>
        </div>
        <a class="mobile-menu" id="mobile-header" href="#!">
            <i class="feather icon-more-horizontal"></i>
        </a>
        <div class="collapse navbar-collapse">
            <ul class="navbar-nav mr-auto">
                <li><a href="#!" class="full-screen" onclick="javascript:toggleFullScreen()"><i class="feather icon-maximize"></i></a></li>
                <li>
                    <h5 class="m-b-0">@ViewData["Title"]</h5>
                    <small>@(ViewData["Subtitle"] ?? "Hệ thống quản lý chung cư")</small>
                </li>
            </ul>
            <ul class="navbar-nav ml-auto">
                <li>
                    <div class="dropdown drp-user">
                        <a href="#" class="dropdown-toggle" data-toggle="dropdown">
                            <i class="icon feather icon-settings"></i>
                        </a>
                        <div class="dropdown-menu dropdown-menu-right profile-notification">
                            <div class="pro-head">
                                <img src="~/images/user/avatar-1.jpg" class="img-radius" alt="User-Profile-Image">
                                <span>@User.Identity?.Name?.Split('@')[0]</span>
                            </div>
                            <ul class="pro-body">
                                <li>
                                    <form asp-action="Logout" asp-controller="Auth" asp-area="" method="post" id="logoutForm" style="display: none;">
                                        @Html.AntiForgeryToken()
                                    </form>
                                    <a href="#" onclick="document.getElementById('logoutForm').submit();" class="dropdown-item">
                                        <i class="feather icon-log-out"></i> Đăng xuất
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </li>
            </ul>
        </div>
    </header>
    <!-- [ Header ] end -->

    <!-- [ Main Content ] start -->
    <div class="pcoded-main-container">
        <div class="pcoded-wrapper">
            <div class="pcoded-content">
                <div class="pcoded-inner-content">
                    <div class="main-body">
                        <div class="page-wrapper">
                            <!-- [ breadcrumb ] start -->
                            <div class="page-header">
                                <div class="page-block">
                                    <div class="row align-items-center">
                                        <div class="col-md-12">
                                            <ul class="breadcrumb">
                                                <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Dashboard" asp-action="Index"><i class="feather icon-home"></i></a></li>
                                                <li class="breadcrumb-item"><a href="#!">Admin</a></li>
                                                <li class="breadcrumb-item"><a href="#!">@ViewContext.RouteData.Values["controller"]?.ToString()</a></li>
                                            </ul>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- [ breadcrumb ] end -->
                            
                            <!-- [ Main Content ] start -->
                            <div class="row">
                                <div class="col-sm-12">
                                    @if (TempData["SuccessMessage"] != null)
                                    {
                                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                                            @TempData["SuccessMessage"]
                                            <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                                        </div>
                                    }
                                    @if (TempData["ErrorMessage"] != null)
                                    {
                                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                            @TempData["ErrorMessage"]
                                            <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                                        </div>
                                    }

                                    @RenderBody()
                                </div>
                            </div>
                            <!-- [ Main Content ] end -->
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- [ Main Content ] end -->

    <!-- Required Js -->
    <script src="~/js/vendor-all.min.js"></script>
    <script src="~/plugins/bootstrap/js/bootstrap.min.js"></script>
    <script src="~/js/pcoded.min.js"></script>
    
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
