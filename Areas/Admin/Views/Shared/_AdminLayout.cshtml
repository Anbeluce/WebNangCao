<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin | Chung cư Smart</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        :root {
            --sidebar-bg: #0f1117;
            --sidebar-width: 260px;
            --accent: #667eea;
            --accent2: #764ba2;
            --text-muted: rgba(255,255,255,0.45);
            --border: rgba(255,255,255,0.08);
            --card-bg: #1a1d27;
            --body-bg: #12151e;
        }

        * { box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--body-bg);
            color: #e2e8f0;
            margin: 0;
            padding: 0;
        }

        /* Sidebar */
        .admin-sidebar {
            position: fixed;
            top: 0; left: 0; bottom: 0;
            width: var(--sidebar-width);
            background: var(--sidebar-bg);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            z-index: 100;
            overflow-y: auto;
        }

        .sidebar-brand {
            padding: 24px 20px;
            border-bottom: 1px solid var(--border);
        }

        .sidebar-brand .brand-icon {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            border-radius: 10px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            margin-bottom: 10px;
        }

        .sidebar-brand h2 {
            font-size: 16px;
            font-weight: 700;
            color: #fff;
            margin: 0;
        }

        .sidebar-brand p {
            font-size: 11px;
            color: var(--text-muted);
            margin: 2px 0 0;
        }

        .sidebar-nav {
            flex: 1;
            padding: 16px 12px;
        }

        .nav-section-label {
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 1.2px;
            text-transform: uppercase;
            color: var(--text-muted);
            padding: 12px 12px 8px;
        }

        .nav-link-admin {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 10px;
            color: rgba(255,255,255,0.65);
            text-decoration: none;
            font-size: 13.5px;
            font-weight: 500;
            transition: all 0.2s ease;
            margin-bottom: 2px;
        }

        .nav-link-admin:hover {
            background: rgba(102,126,234,0.15);
            color: #fff;
        }

        .nav-link-admin.active {
            background: linear-gradient(135deg, rgba(102,126,234,0.25), rgba(118,75,162,0.25));
            color: #fff;
            border: 1px solid rgba(102,126,234,0.3);
        }

        .nav-link-admin .nav-icon { font-size: 18px; width: 22px; text-align: center; }

        .sidebar-footer {
            padding: 16px 20px;
            border-top: 1px solid var(--border);
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 12px;
        }

        .user-avatar {
            width: 36px;
            height: 36px;
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            flex-shrink: 0;
        }

        .user-details { min-width: 0; }

        .user-name {
            font-size: 13px;
            font-weight: 600;
            color: #fff;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .user-role {
            font-size: 11px;
            color: var(--text-muted);
        }

        .btn-logout {
            width: 100%;
            padding: 9px;
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.2);
            border-radius: 10px;
            color: #fca5a5;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .btn-logout:hover {
            background: rgba(239, 68, 68, 0.2);
            color: #fff;
        }

        /* Main content */
        .admin-main {
            margin-left: var(--sidebar-width);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .admin-topbar {
            background: var(--card-bg);
            border-bottom: 1px solid var(--border);
            padding: 16px 28px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 50;
        }

        .topbar-title h1 {
            font-size: 20px;
            font-weight: 700;
            color: #fff;
            margin: 0;
        }

        .topbar-title p {
            font-size: 12px;
            color: var(--text-muted);
            margin: 2px 0 0;
        }

        .admin-content {
            flex: 1;
            padding: 28px;
        }

        /* Cards */
        .admin-card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 24px;
            margin-bottom: 20px;
        }

        /* Alerts */
        .alert-success-dark {
            background: rgba(34,197,94,0.12);
            border: 1px solid rgba(34,197,94,0.25);
            color: #86efac;
            border-radius: 12px;
            padding: 12px 16px;
            font-size: 13px;
            margin-bottom: 20px;
        }

        .alert-error-dark {
            background: rgba(239,68,68,0.12);
            border: 1px solid rgba(239,68,68,0.25);
            color: #fca5a5;
            border-radius: 12px;
            padding: 12px 16px;
            font-size: 13px;
            margin-bottom: 20px;
        }

        /* Fix dropdown/select dark theme */
        select, select option {
            background-color: #1a1d27 !important;
            color: #e2e8f0 !important;
        }

        select option:hover,
        select option:checked {
            background-color: #2d3148 !important;
        }

        input, select, textarea {
            color-scheme: dark;
        }

        input[type="date"],
        input[type="number"],
        input[type="text"],
        input[type="email"],
        input[type="password"] {
            background-color: rgba(255,255,255,0.06) !important;
            color: #e2e8f0 !important;
        }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <nav class="admin-sidebar">
        <div class="sidebar-brand">
            <div class="brand-icon">🏢</div>
            <h2>Chung cư Smart</h2>
            <p>Admin Panel</p>
        </div>

        <div class="sidebar-nav">
            <div class="nav-section-label">Tổng quan</div>
            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index"
               class="nav-link-admin @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                <span class="nav-icon">📊</span> Dashboard
            </a>

            <div class="nav-section-label">Quản lý</div>
            <a asp-area="Admin" asp-controller="User" asp-action="Index"
               class="nav-link-admin @(ViewContext.RouteData.Values["controller"]?.ToString() == "User" ? "active" : "")">
                <span class="nav-icon">👥</span> Người dùng
            </a>
            <a asp-area="Admin" asp-controller="Apartment" asp-action="Index"
               class="nav-link-admin @(ViewContext.RouteData.Values["controller"]?.ToString() == "Apartment" ? "active" : "")">
                <span class="nav-icon">🏠</span> Căn hộ
            </a>
            <a asp-area="Admin" asp-controller="Invoice" asp-action="Index"
               class="nav-link-admin @(ViewContext.RouteData.Values["controller"]?.ToString() == "Invoice" ? "active" : "")">
                <span class="nav-icon">📄</span> Hóa đơn
            </a>
            <a asp-area="Admin" asp-controller="Utility" asp-action="Index"
               class="nav-link-admin @(ViewContext.RouteData.Values["controller"]?.ToString() == "Utility" ? "active" : "")">
                <span class="nav-icon">⚡</span> Tiện ích
            </a>

            <div class="nav-section-label">Hệ thống</div>
            <a asp-area="" asp-controller="Home" asp-action="Index" class="nav-link-admin">
                <span class="nav-icon">🌐</span> Trang chủ
            </a>
        </div>

        <div class="sidebar-footer">
            <div class="user-info">
                <div class="user-avatar">👤</div>
                <div class="user-details">
                    <div class="user-name">@User.Identity?.Name?.Split('@')[0]</div>
                    <div class="user-role">Quản trị viên</div>
                </div>
            </div>
            <form asp-action="Logout" asp-controller="Auth" asp-area="" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-logout">🚪 Đăng xuất</button>
            </form>
        </div>
    </nav>

    <!-- Main -->
    <div class="admin-main">
        <div class="admin-topbar">
            <div class="topbar-title">
                <h1>@ViewData["Title"]</h1>
                <p>@(ViewData["Subtitle"] ?? "Hệ thống quản lý chung cư")</p>
            </div>
            <div style="font-size:12px;color:rgba(255,255,255,0.35);">
                @DateTime.Now.ToString("dd/MM/yyyy HH:mm")
            </div>
        </div>

        <div class="admin-content">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert-success-dark">✅ @TempData["SuccessMessage"]</div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert-error-dark">❌ @TempData["ErrorMessage"]</div>
            }

            @RenderBody()
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
