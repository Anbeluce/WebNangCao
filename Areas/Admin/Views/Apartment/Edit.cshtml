@model EditApartmentVM
@{
    ViewData["Title"] = "Sửa căn hộ";
    ViewData["Subtitle"] = $"Chỉnh sửa thông tin căn hộ {Model.ApartmentNumber}";
}

<div class="row">
    <div class="col-sm-12 col-md-8 col-xl-6">
        <div class="card">
            <div class="card-header">
                <h5>Cập nhật thông tin căn hộ</h5>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <div class="form-group">
                        <label asp-for="ApartmentNumber" class="form-label">Số căn hộ <span class="text-danger">*</span></label>
                        <input asp-for="ApartmentNumber" class="form-control" />
                        <span asp-validation-for="ApartmentNumber" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Area" class="form-label">Diện tích (m²) <span class="text-danger">*</span></label>
                                <input asp-for="Area" type="number" step="0.1" class="form-control" />
                                <span asp-validation-for="Area" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Floor" class="form-label">Tầng <span class="text-danger">*</span></label>
                                <input asp-for="Floor" type="number" class="form-control" />
                                <span asp-validation-for="Floor" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="OwnerId" class="form-label">Chủ sở hữu</label>
                        <select asp-for="OwnerId" asp-items="@(ViewBag.Owners as SelectList)" class="form-control">
                            <option value="">-- Chưa có chủ sở hữu --</option>
                        </select>
                        <span asp-validation-for="OwnerId" class="text-danger small"></span>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-warning text-dark"><i class="feather icon-save"></i> Cập nhật</button>
                        <a asp-action="Index" class="btn btn-light"><i class="feather icon-arrow-left"></i> Quay lại</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
