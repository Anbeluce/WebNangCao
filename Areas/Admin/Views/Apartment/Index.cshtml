@model List<ApartmentListVM>
@{
    ViewData["Title"] = "Quản lý căn hộ";
    ViewData["Subtitle"] = "Danh sách căn hộ trong chung cư";
}

@section Styles {
    <!-- data tables css -->
    <link rel="stylesheet" href="~/plugins/data-tables/css/datatables.min.css">
}

<div class="row">
    <!-- Zero config table start -->
    <div class="col-sm-12">
        <div class="card">
            <div class="card-header border-bottom">
                <div class="d-flex align-items-center justify-content-between">
                    <h5>Danh sách căn hộ</h5>
                    <a asp-action="Create" class="btn btn-primary btn-sm">
                        <i class="feather icon-plus"></i> Thêm căn hộ
                    </a>
                </div>
            </div>
            <div class="card-body">
                <div class="dt-responsive table-responsive">
                    <table id="simpletable" class="table table-striped table-bordered nowrap">
                        <thead>
                            <tr>
                                <th>Số căn hộ</th>
                                <th>Tầng</th>
                                <th>Diện tích</th>
                                <th>Chủ sở hữu</th>
                                <th>Hóa đơn</th>
                                <th>Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <h6 class="m-0">@item.ApartmentNumber</h6>
                                    </td>
                                    <td>Tầng @item.Floor</td>
                                    <td>@item.Area m²</td>
                                    <td>
                                        @if (item.OwnerName != null)
                                        {
                                            <div class="d-inline-block">
                                                <h6 class="m-b-0">@item.OwnerName</h6>
                                                <p class="m-b-0 text-muted">@item.OwnerEmail</p>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted font-italic">Chưa có chủ</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge badge-light-primary">@item.InvoiceCount hóa đơn</span>
                                    </td>
                                    <td>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-icon btn-outline-warning btn-sm" title="Chỉnh sửa">
                                            <i class="feather icon-edit"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Bạn có chắc muốn xóa căn hộ @item.ApartmentNumber?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-icon btn-outline-danger btn-sm" title="Xóa">
                                                <i class="feather icon-trash-2"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <!-- Zero config table end -->
</div>

@section Scripts {
    <!-- datatable Js -->
    <script src="~/plugins/data-tables/js/datatables.min.js"></script>
    <script>
        $(document).ready(function() {
            $('#simpletable').DataTable({
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.10.24/i18n/Vietnamese.json"
                },
                "pageLength": 10
            });
        });
    </script>
}
