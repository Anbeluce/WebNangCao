@{
    ViewData["Title"] = "Dashboard";
    ViewData["Subtitle"] = "Tổng quan hệ thống";
}

<!-- Stats Cards -->
<div class="row">
    <div class="col-md-6 col-xl-3">
        <div class="card bg-c-blue order-card">
            <div class="card-body">
                <h6 class="text-white">Tổng người dùng</h6>
                <h2 class="text-white">@ViewBag.TotalUsers</h2>
                <i class="feather icon-users card-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card bg-c-green order-card">
            <div class="card-body">
                <h6 class="text-white">TK hoạt động</h6>
                <h2 class="text-white">@ViewBag.ActiveUsers</h2>
                <i class="feather icon-user-check card-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card bg-c-yellow order-card">
            <div class="card-body">
                <h6 class="text-white">Căn hộ</h6>
                <h2 class="text-white">@ViewBag.TotalApartments</h2>
                <i class="feather icon-home card-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card bg-c-red order-card">
            <div class="card-body">
                <h6 class="text-white">Hóa đơn</h6>
                <h2 class="text-white">@ViewBag.TotalInvoices</h2>
                <i class="feather icon-file-text card-icon"></i>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h5>⚡ Truy cập nhanh</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4 mb-3">
                        <a asp-area="Admin" asp-controller="User" asp-action="Index" class="btn btn-outline-primary btn-block text-left p-3">
                            <i class="feather icon-users text-primary f-24 d-block mb-2"></i>
                            <span class="d-block font-weight-bold f-16 text-body">Quản lý người dùng</span>
                            <span class="d-block text-muted mt-1 f-12">Xem và quản lý tài khoản</span>
                        </a>
                    </div>
                    <div class="col-md-4 mb-3">
                        <a asp-area="Admin" asp-controller="User" asp-action="Create" class="btn btn-outline-success btn-block text-left p-3">
                            <i class="feather icon-user-plus text-success f-24 d-block mb-2"></i>
                            <span class="d-block font-weight-bold f-16 text-body">Thêm người dùng</span>
                            <span class="d-block text-muted mt-1 f-12">Tạo tài khoản mới</span>
                        </a>
                    </div>
                    <div class="col-md-4 mb-3">
                        <a asp-area="Admin" asp-controller="Apartment" asp-action="Index" class="btn btn-outline-warning btn-block text-left p-3">
                            <i class="feather icon-home text-warning f-24 d-block mb-2"></i>
                            <span class="d-block font-weight-bold f-16 text-body">Quản lý căn hộ</span>
                            <span class="d-block text-muted mt-1 f-12">Xem danh sách căn hộ</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
