@{
    ViewData["Title"] = "Dashboard";
    ViewData["Subtitle"] = "Tổng quan hệ thống";
}

<div class="row g-4 mb-4">
    <!-- Stats Cards -->
    <div class="col-md-3">
        <div style="background:linear-gradient(135deg,rgba(102,126,234,0.2),rgba(118,75,162,0.2));border:1px solid rgba(102,126,234,0.3);border-radius:16px;padding:24px;">
            <div style="font-size:32px;margin-bottom:12px;">👥</div>
            <div style="font-size:28px;font-weight:700;color:#fff;">@ViewBag.TotalUsers</div>
            <div style="font-size:13px;color:rgba(255,255,255,0.55);margin-top:4px;">Tổng người dùng</div>
        </div>
    </div>
    <div class="col-md-3">
        <div style="background:linear-gradient(135deg,rgba(17,153,142,0.2),rgba(56,239,125,0.2));border:1px solid rgba(17,153,142,0.3);border-radius:16px;padding:24px;">
            <div style="font-size:32px;margin-bottom:12px;">✅</div>
            <div style="font-size:28px;font-weight:700;color:#fff;">@ViewBag.ActiveUsers</div>
            <div style="font-size:13px;color:rgba(255,255,255,0.55);margin-top:4px;">Tài khoản hoạt động</div>
        </div>
    </div>
    <div class="col-md-3">
        <div style="background:linear-gradient(135deg,rgba(245,158,11,0.2),rgba(252,211,77,0.2));border:1px solid rgba(245,158,11,0.3);border-radius:16px;padding:24px;">
            <div style="font-size:32px;margin-bottom:12px;">🏠</div>
            <div style="font-size:28px;font-weight:700;color:#fff;">@ViewBag.TotalApartments</div>
            <div style="font-size:13px;color:rgba(255,255,255,0.55);margin-top:4px;">Căn hộ</div>
        </div>
    </div>
    <div class="col-md-3">
        <div style="background:linear-gradient(135deg,rgba(239,68,68,0.2),rgba(252,165,165,0.2));border:1px solid rgba(239,68,68,0.3);border-radius:16px;padding:24px;">
            <div style="font-size:32px;margin-bottom:12px;">📄</div>
            <div style="font-size:28px;font-weight:700;color:#fff;">@ViewBag.TotalInvoices</div>
            <div style="font-size:13px;color:rgba(255,255,255,0.55);margin-top:4px;">Hóa đơn</div>
        </div>
    </div>
</div>

<div class="admin-card">
    <h5 style="font-weight:600;color:#fff;margin-bottom:16px;">⚡ Truy cập nhanh</h5>
    <div class="row g-3">
        <div class="col-md-4">
            <a asp-area="Admin" asp-controller="User" asp-action="Index"
               style="display:block;background:rgba(102,126,234,0.1);border:1px solid rgba(102,126,234,0.2);border-radius:12px;padding:16px;text-decoration:none;transition:all 0.2s ease;"
               onmouseover="this.style.background='rgba(102,126,234,0.2)'" onmouseout="this.style.background='rgba(102,126,234,0.1)'">
                <div style="font-size:24px;margin-bottom:8px;">👥</div>
                <div style="color:#fff;font-weight:600;font-size:14px;">Quản lý người dùng</div>
                <div style="color:rgba(255,255,255,0.45);font-size:12px;margin-top:4px;">Xem và quản lý tài khoản</div>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-area="Admin" asp-controller="User" asp-action="Create"
               style="display:block;background:rgba(17,153,142,0.1);border:1px solid rgba(17,153,142,0.2);border-radius:12px;padding:16px;text-decoration:none;transition:all 0.2s ease;"
               onmouseover="this.style.background='rgba(17,153,142,0.2)'" onmouseout="this.style.background='rgba(17,153,142,0.1)'">
                <div style="font-size:24px;margin-bottom:8px;">➕</div>
                <div style="color:#fff;font-weight:600;font-size:14px;">Thêm người dùng</div>
                <div style="color:rgba(255,255,255,0.45);font-size:12px;margin-top:4px;">Tạo tài khoản mới</div>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-area="Admin" asp-controller="Apartment" asp-action="Index"
               style="display:block;background:rgba(245,158,11,0.1);border:1px solid rgba(245,158,11,0.2);border-radius:12px;padding:16px;text-decoration:none;transition:all 0.2s ease;"
               onmouseover="this.style.background='rgba(245,158,11,0.2)'" onmouseout="this.style.background='rgba(245,158,11,0.1)'">
                <div style="font-size:24px;margin-bottom:8px;">🏠</div>
                <div style="color:#fff;font-weight:600;font-size:14px;">Quản lý căn hộ</div>
                <div style="color:rgba(255,255,255,0.45);font-size:12px;margin-top:4px;">Xem danh sách căn hộ</div>
            </a>
        </div>
    </div>
</div>
