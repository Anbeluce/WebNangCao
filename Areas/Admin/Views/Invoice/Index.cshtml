@model List<InvoiceListVM>
@{
    ViewData["Title"] = "Quản lý hóa đơn";
    ViewData["Subtitle"] = "Tạo và quản lý hóa đơn nước, phí dịch vụ";
}

@section Styles {
    <!-- data tables css -->
    <link rel="stylesheet" href="~/plugins/data-tables/css/datatables.min.css">
    <!-- Select2 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <style>
        .select2-container .select2-selection--single {
            height: 43px;
            border: 1px solid #ced4da;
            padding: 6px 12px;
        }
        .select2-container--default .select2-selection--single .select2-selection__arrow {
            height: 41px;
        }
    </style>
}

<!-- Statistics Cards -->
<div class="row">
    <div class="col-md-6 col-xl-3">
        <div class="card bg-c-blue order-card">
            <div class="card-body">
                <h6 class="text-white">Tổng hóa đơn</h6>
                <h2 class="text-white">@ViewBag.TotalInvoices</h2>
                <i class="feather icon-file-text card-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card bg-c-red order-card">
            <div class="card-body">
                <h6 class="text-white">Chưa thanh toán</h6>
                <h2 class="text-white">@ViewBag.UnpaidCount</h2>
                <i class="feather icon-alert-circle card-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card bg-c-green order-card">
            <div class="card-body">
                <h6 class="text-white">Đã thanh toán</h6>
                <h2 class="text-white">@ViewBag.PaidCount</h2>
                <i class="feather icon-check-circle card-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card bg-c-yellow order-card">
            <div class="card-body">
                <h6 class="text-white">Doanh thu</h6>
                <h2 class="text-white">@(((decimal)ViewBag.TotalRevenue).ToString("N0"))đ</h2>
                <i class="feather icon-dollar-sign card-icon"></i>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-sm-12">
        <div class="card">
            <div class="card-header border-bottom">
                <div class="d-flex align-items-center justify-content-between">
                    <h5>Danh sách hóa đơn</h5>
                    <div>
                        <button type="button" class="btn btn-success btn-sm mr-2" data-toggle="modal" data-target="#importExcelModal">
                            <i class="feather icon-upload"></i> Nhập từ Excel
                        </button>
                        <a asp-action="Create" class="btn btn-primary btn-sm">
                            <i class="feather icon-plus"></i> Tạo hóa đơn
                        </a>
                    </div>
                </div>
            </div>
            <div class="card-body">
                <!-- Filter form -->
                <form method="get" class="mb-4">
                    <div class="row align-items-end">
                        <div class="col-md-3 mb-2">
                            <label class="form-label">Tháng</label>
                            <select name="month" class="form-control">
                                <option value="">Tất cả tháng</option>
                                @for (int m = 1; m <= 12; m++)
                                {
                                    <option value="@m" selected="@(ViewBag.FilterMonth != null && (int)ViewBag.FilterMonth == m)">Tháng @m</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3 mb-2">
                            <label class="form-label">Năm</label>
                            <select name="year" class="form-control">
                                <option value="">Tất cả năm</option>
                                @for (int y = DateTime.UtcNow.AddHours(7).Year; y >= 2020; y--)
                                {
                                    <option value="@y" selected="@(ViewBag.FilterYear != null && (int)ViewBag.FilterYear == y)">@y</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3 mb-2">
                            <label class="form-label">Căn hộ</label>
                            <select name="apartmentId" asp-items="@(ViewBag.Apartments as SelectList)" class="form-control select2">
                                <option value="">Tất cả căn hộ</option>
                            </select>
                        </div>
                        <div class="col-md-3 mb-2">
                            <button type="submit" class="btn btn-info btn-block"><i class="feather icon-filter"></i> Lọc</button>
                        </div>
                    </div>
                </form>

                <div class="dt-responsive table-responsive">
                    <table id="simpletable" class="table table-striped table-bordered nowrap">
                        <thead>
                            <tr>
                                <th>Căn hộ</th>
                                <th>Kỳ</th>
                                <th class="text-right">Nước</th>
                                <th class="text-right">Phí quản lý</th>
                                <th class="text-right">Phí cố định</th>
                                <th class="text-right">Tổng cộng</th>
                                <th class="text-center">Trạng thái</th>
                                <th class="text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var inv in Model)
                            {
                                <tr>
                                    <td>
                                        <h6 class="m-0">@inv.ApartmentNumber</h6>
                                        @if(inv.OwnerName != null)
                                        {
                                            <p class="m-0 text-muted">@inv.OwnerName</p>
                                        }
                                    </td>
                                    <td>T@(inv.Month)/@inv.Year</td>
                                    <td class="text-right">
                                        <span class="text-info">@inv.WaterFee.ToString("N0")đ</span>
                                        <br><small class="text-muted">@inv.WaterUsage m³</small>
                                    </td>
                                    <td class="text-right text-primary">
                                        @inv.ManagementFee.ToString("N0")đ
                                    </td>
                                    <td class="text-right text-muted">
                                        @((inv.WasteFee + inv.ParkingFee).ToString("N0"))đ
                                        <br><small class="text-muted">VS: @inv.WasteFee.ToString("N0")đ | Xe: @inv.ParkingFee.ToString("N0")đ</small>
                                    </td>
                                    <td class="text-right font-weight-bold text-success">@inv.TotalAmount.ToString("N0")đ</td>
                                    <td class="text-center">
                                         @if (inv.Status == InvoiceStatus.Paid)
                                         {
                                             <span class="badge badge-success px-2 py-1 font-weight-bold" style="border-radius: 4px;">Đã thanh toán</span>
                                         }
                                         else if (inv.Status == InvoiceStatus.Partial)
                                         {
                                             <span class="badge badge-warning text-dark px-2 py-1 font-weight-bold" style="border-radius: 4px;">Một phần</span>
                                         }
                                         else
                                         {
                                             <span class="badge badge-danger px-2 py-1 font-weight-bold" style="border-radius: 4px;">Chưa thanh toán</span>
                                         }
                                    </td>
                                    <td class="text-center">
                                        <a asp-action="Edit" asp-route-id="@inv.Id" class="btn btn-icon btn-outline-warning btn-sm" title="Sửa">
                                            <i class="feather icon-edit"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@inv.Id" method="post" style="display:inline;" onsubmit="return confirm('Xóa hóa đơn này?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-icon btn-outline-danger btn-sm" title="Xóa">
                                                <i class="feather icon-trash-2"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal nhập từ Excel -->
<div id="importExcelModal" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="importExcelModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content" style="border-radius: 12px; border: none; overflow: hidden;">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title text-white" id="importExcelModalLabel"><i class="feather icon-upload"></i> Nhập hóa đơn từ tệp Excel</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
            </div>
            <form asp-action="ImportExcel" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <p class="text-muted small mb-3">Tải tệp Excel chứa số liệu hóa đơn của bạn. Hãy đảm bảo các căn hộ trong tệp đã có cư dân đăng ký sở hữu.</p>
                    
                    <div class="alert alert-info py-2 px-3 small mb-4" style="border-radius: 6px; background-color: #e8f4fd; border: 1px solid #b8dbf7; color: #1d4ed8;">
                        <i class="feather icon-info mr-1"></i> Để có định dạng chuẩn xác nhất, vui lòng tải và sử dụng tệp mẫu của hệ thống.
                    </div>

                    <div class="text-center mb-4">
                        <a asp-action="DownloadTemplate" class="btn btn-outline-success btn-sm font-weight-bold" style="border-radius: 6px;">
                            <i class="feather icon-download-cloud mr-1"></i> Tải Tệp Excel Mẫu (.xlsx)
                        </a>
                    </div>

                    <div class="form-group mb-0">
                        <label class="form-label font-weight-bold">Chọn tệp Excel nhập liệu <span class="text-danger">*</span></label>
                        <div class="custom-file">
                            <input type="file" name="excelFile" accept=".xlsx, .xls" class="custom-file-input" id="excelFileInput" required />
                            <label class="custom-file-label" for="excelFileInput" data-browse="Chọn">Chọn file...</label>
                        </div>
                        <small class="text-muted mt-2 d-block">Hỗ trợ tệp định dạng `.xlsx` hoặc `.xls`</small>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal" style="border-radius: 4px;">Hủy</button>
                    <button type="submit" class="btn btn-success btn-sm font-weight-bold" style="border-radius: 4px;"><i class="feather icon-check-circle mr-1"></i> Nhập dữ liệu</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <!-- datatable Js -->
    <script src="~/plugins/data-tables/js/datatables.min.js"></script>
    <!-- Select2 JS -->
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        $(document).ready(function() {
            $('#simpletable').DataTable({
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.10.24/i18n/Vietnamese.json"
                },
                "pageLength": 10,
                "ordering": false // to keep server order if any
            });
            
            $('.select2').select2({
                placeholder: "Tất cả căn hộ",
                allowClear: true,
                width: '100%'
            });

            // Cập nhật tên file chọn trên input file Bootstrap
            $('#excelFileInput').on('change', function() {
                var fileName = $(this).val().split('\\').pop();
                $(this).next('.custom-file-label').addClass("selected").html(fileName);
            });
        });
    </script>
}
