@model List<InvoiceListVM>
@{
    ViewData["Title"] = "Quản lý hóa đơn";
    ViewData["Subtitle"] = "Tạo và quản lý hóa đơn điện nước, phí dịch vụ";
}

<div style="display:grid; grid-template-columns:repeat(4, 1fr); gap:14px; margin-bottom:24px;">
    <div class="admin-card" style="margin-bottom:0; padding:18px;">
        <div style="font-size:11px; color:rgba(255,255,255,0.45); text-transform:uppercase;">Tổng hóa đơn</div>
        <div style="font-size:26px; font-weight:700; color:#fff; margin-top:6px;">@ViewBag.TotalInvoices</div>
    </div>
    <div class="admin-card" style="margin-bottom:0; padding:18px;">
        <div style="font-size:11px; color:rgba(255,255,255,0.45); text-transform:uppercase;">Chưa thanh toán</div>
        <div style="font-size:26px; font-weight:700; color:#f87171; margin-top:6px;">@ViewBag.UnpaidCount</div>
    </div>
    <div class="admin-card" style="margin-bottom:0; padding:18px;">
        <div style="font-size:11px; color:rgba(255,255,255,0.45); text-transform:uppercase;">Đã thanh toán</div>
        <div style="font-size:26px; font-weight:700; color:#4ade80; margin-top:6px;">@ViewBag.PaidCount</div>
    </div>
    <div class="admin-card" style="margin-bottom:0; padding:18px;">
        <div style="font-size:11px; color:rgba(255,255,255,0.45); text-transform:uppercase;">Doanh thu</div>
        <div style="font-size:26px; font-weight:700; color:#fbbf24; margin-top:6px;">@(((decimal)ViewBag.TotalRevenue).ToString("N0"))đ</div>
    </div>
</div>

<div class="admin-card" style="padding:16px 20px;">
    <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:12px;">
        <form method="get" style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
            <select name="month" style="background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.1); color:#fff; border-radius:8px; padding:7px 12px; font-size:13px;">
                <option value="">Tất cả tháng</option>
                @for (int m = 1; m <= 12; m++)
                {
                    <option value="@m" selected="@(ViewBag.FilterMonth != null && (int)ViewBag.FilterMonth == m)">Tháng @m</option>
                }
            </select>
            <select name="year" style="background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.1); color:#fff; border-radius:8px; padding:7px 12px; font-size:13px;">
                <option value="">Tất cả năm</option>
                @for (int y = DateTime.Now.Year; y >= 2020; y--)
                {
                    <option value="@y" selected="@(ViewBag.FilterYear != null && (int)ViewBag.FilterYear == y)">@y</option>
                }
            </select>
            <select name="apartmentId" asp-items="@(ViewBag.Apartments as SelectList)" style="background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.1); color:#fff; border-radius:8px; padding:7px 12px; font-size:13px;">
                <option value="">Tất cả căn hộ</option>
            </select>
            <button type="submit" style="padding:7px 16px; background:rgba(102,126,234,0.15); border:1px solid rgba(102,126,234,0.3); color:#a5b4fc; border-radius:8px; font-size:13px; cursor:pointer;">🔍 Lọc</button>
            <a asp-action="Index" style="padding:7px 12px; color:rgba(255,255,255,0.4); text-decoration:none; font-size:13px;">↻ Xóa lọc</a>
        </form>
        <div style="display:flex; gap:10px;">
            <button onclick="document.getElementById('batchModal').style.display='flex'" style="padding:8px 16px; background:rgba(74,222,128,0.12); border:1px solid rgba(74,222,128,0.25); color:#4ade80; border-radius:8px; font-size:13px; font-weight:600; cursor:pointer;">📦 Tạo hàng loạt</button>
            <a asp-action="Create" style="padding:8px 16px; background:linear-gradient(135deg,#667eea,#764ba2); color:#fff; border-radius:8px; text-decoration:none; font-size:13px; font-weight:600;">➕ Tạo hóa đơn</a>
        </div>
    </div>
</div>

<div class="admin-card" style="padding:0; overflow-x:auto;">
    <table style="width:100%; border-collapse:collapse; font-size:13px; min-width:850px;">
        <thead>
            <tr style="background:rgba(102,126,234,0.1); border-bottom:1px solid rgba(255,255,255,0.08);">
                <th style="padding:12px 14px; text-align:left; font-size:11px; color:rgba(255,255,255,0.7); text-transform:uppercase;">Căn hộ</th>
                <th style="padding:12px 14px; text-align:left; font-size:11px; color:rgba(255,255,255,0.7); text-transform:uppercase;">Kỳ</th>
                <th style="padding:12px 14px; text-align:right; font-size:11px; color:rgba(255,255,255,0.7); text-transform:uppercase;">⚡ Điện</th>
                <th style="padding:12px 14px; text-align:right; font-size:11px; color:rgba(255,255,255,0.7); text-transform:uppercase;">💧 Nước</th>
                <th style="padding:12px 14px; text-align:right; font-size:11px; color:rgba(255,255,255,0.7); text-transform:uppercase;">Phí DV</th>
                <th style="padding:12px 14px; text-align:right; font-size:11px; color:rgba(255,255,255,0.7); text-transform:uppercase;">Tổng</th>
                <th style="padding:12px 14px; text-align:center; font-size:11px; color:rgba(255,255,255,0.7); text-transform:uppercase;">TT</th>
                <th style="padding:12px 14px; text-align:center; font-size:11px; color:rgba(255,255,255,0.7); text-transform:uppercase;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="8" style="padding:40px; text-align:center; color:rgba(255,255,255,0.4);">📄 Chưa có hóa đơn nào.</td></tr>
            }
            @foreach (var inv in Model)
            {
                var sColor = inv.Status == InvoiceStatus.Paid ? "#4ade80" : inv.Status == InvoiceStatus.Partial ? "#fbbf24" : "#f87171";
                var sBg = inv.Status == InvoiceStatus.Paid ? "rgba(74,222,128,0.12)" : inv.Status == InvoiceStatus.Partial ? "rgba(251,191,36,0.12)" : "rgba(248,113,113,0.12)";
                var sTxt = inv.Status == InvoiceStatus.Paid ? "Đã TT" : inv.Status == InvoiceStatus.Partial ? "Một phần" : "Chưa TT";
                <tr style="border-bottom:1px solid rgba(255,255,255,0.05);" onmouseover="this.style.background='rgba(102,126,234,0.05)'" onmouseout="this.style.background='transparent'">
                    <td style="padding:10px 14px;"><strong style="color:#fff;">@inv.ApartmentNumber</strong>
                        @if(inv.OwnerName!=null){<div style="font-size:11px;color:rgba(255,255,255,0.35);">@inv.OwnerName</div>}
                    </td>
                    <td style="padding:10px 14px; color:rgba(255,255,255,0.7);">T@(inv.Month)/@inv.Year</td>
                    <td style="padding:10px 14px; text-align:right;">
                        <span style="color:#fbbf24;">@inv.ElectricityFee.ToString("N0")đ</span>
                        <div style="font-size:10px;color:rgba(255,255,255,0.3);">@inv.ElectricityUsage kWh</div>
                    </td>
                    <td style="padding:10px 14px; text-align:right;">
                        <span style="color:#60a5fa;">@inv.WaterFee.ToString("N0")đ</span>
                        <div style="font-size:10px;color:rgba(255,255,255,0.3);">@inv.WaterUsage m³</div>
                    </td>
                    <td style="padding:10px 14px; text-align:right; color:#a78bfa;">@inv.ServiceFee.ToString("N0")đ</td>
                    <td style="padding:10px 14px; text-align:right; font-weight:700; color:#fff;">@inv.TotalAmount.ToString("N0")đ</td>
                    <td style="padding:10px 14px; text-align:center;">
                        <span style="padding:3px 9px; background:@sBg; color:@sColor; border-radius:20px; font-size:11px; font-weight:600;">@sTxt</span>
                    </td>
                    <td style="padding:10px 14px; text-align:center;">
                        <a asp-action="Edit" asp-route-id="@inv.Id" style="color:#667eea; text-decoration:none; font-size:12px; margin-right:8px;">✏️ Sửa</a>
                        <form asp-action="Delete" asp-route-id="@inv.Id" method="post" style="display:inline;" onsubmit="return confirm('Xóa hóa đơn này?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" style="background:none; border:none; color:#f87171; cursor:pointer; font-size:12px;">🗑️ Xóa</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Modal tạo hàng loạt -->
<div id="batchModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.6); z-index:1000; align-items:center; justify-content:center;" onclick="if(event.target===this)this.style.display='none'">
    <div style="background:#1a1d27; border:1px solid rgba(255,255,255,0.1); border-radius:16px; padding:28px; width:420px;">
        <h3 style="margin:0 0 16px; font-size:17px; font-weight:600; color:#fff;">📦 Tạo hóa đơn hàng loạt</h3>
        <p style="font-size:12px; color:rgba(255,255,255,0.45); margin-bottom:16px;">Tạo cho tất cả căn hộ có chủ. Số điện/nước = 0, cập nhật sau.</p>
        <form asp-action="CreateBatch" method="post">
            @Html.AntiForgeryToken()
            <div style="display:flex; gap:12px; margin-bottom:14px;">
                <div style="flex:1;">
                    <label style="display:block; font-size:12px; color:rgba(255,255,255,0.6); margin-bottom:5px;">Tháng</label>
                    <select name="month" style="width:100%; background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.1); color:#fff; border-radius:8px; padding:9px;">
                        @for (int m = 1; m <= 12; m++){<option value="@m" selected="@(m == DateTime.Now.Month)">Tháng @m</option>}
                    </select>
                </div>
                <div style="flex:1;">
                    <label style="display:block; font-size:12px; color:rgba(255,255,255,0.6); margin-bottom:5px;">Năm</label>
                    <input type="number" name="year" value="@DateTime.Now.Year" style="width:100%; background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.1); color:#fff; border-radius:8px; padding:9px;" />
                </div>
            </div>
            <div style="margin-bottom:18px;">
                <label style="display:block; font-size:12px; color:rgba(255,255,255,0.6); margin-bottom:5px;">Phí dịch vụ (VNĐ/m²)</label>
                <input type="number" name="serviceFeePerM2" value="15000" step="1000" style="width:100%; background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.1); color:#fff; border-radius:8px; padding:9px;" />
            </div>
            <div style="display:flex; gap:10px; justify-content:flex-end;">
                <button type="button" onclick="document.getElementById('batchModal').style.display='none'" style="padding:9px 18px; background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.1); color:rgba(255,255,255,0.6); border-radius:8px; cursor:pointer;">Hủy</button>
                <button type="submit" style="padding:9px 18px; background:linear-gradient(135deg,#667eea,#764ba2); border:none; color:#fff; border-radius:8px; cursor:pointer; font-weight:600;">📦 Tạo</button>
            </div>
        </form>
    </div>
</div>
