@model CreateInvoiceVM
@{
    ViewData["Title"] = "Tạo hóa đơn";
    ViewData["Subtitle"] = "Tạo hóa đơn điện nước cho căn hộ";
}

<div class="row">
    <div class="col-sm-12 col-md-10 col-xl-8">
        <div class="card">
            <div class="card-header">
                <h5>Thông tin hóa đơn</h5>
            </div>
            <div class="card-body">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        <div asp-validation-summary="ModelOnly" class="mb-0"></div>
                    </div>
                }

                <form asp-action="Create" method="post" id="invoiceForm">
                    @Html.AntiForgeryToken()

                    <div class="form-group">
                        <label asp-for="ApartmentId" class="form-label">Căn hộ <span class="text-danger">*</span></label>
                        <select asp-for="ApartmentId" asp-items="@(ViewBag.Apartments as SelectList)" class="form-control">
                            <option value="">-- Chọn căn hộ --</option>
                        </select>
                        <span asp-validation-for="ApartmentId" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Month" class="form-label">Tháng <span class="text-danger">*</span></label>
                                <select asp-for="Month" class="form-control">
                                    @for (int m = 1; m <= 12; m++){<option value="@m">Tháng @m</option>}
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Year" class="form-label">Năm <span class="text-danger">*</span></label>
                                <input asp-for="Year" type="number" class="form-control" />
                            </div>
                        </div>
                    </div>

                    <!-- Điện -->
                    <h6 class="mt-4 mb-3 text-warning"><i class="feather icon-zap"></i> Tiền điện</h6>
                    <div class="row align-items-end mb-4">
                        <div class="col-md-4">
                            <div class="form-group mb-md-0">
                                <label class="form-label">Số kWh tiêu thụ</label>
                                <input asp-for="ElectricityUsage" type="number" step="0.1" placeholder="VD: 150" id="elecUsage" oninput="calcTotal()" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-1 text-center d-none d-md-block">
                            <span class="f-20 text-muted">×</span>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group mb-md-0">
                                <label class="form-label">Đơn giá (đ/kWh)</label>
                                <input asp-for="ElectricityUnitPrice" type="number" step="100" id="elecPrice" oninput="calcTotal()" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-1 text-center d-none d-md-block">
                            <span class="f-20 text-muted">=</span>
                        </div>
                        <div class="col-md-2 text-right">
                            <small class="text-muted d-block">Thành tiền</small>
                            <span id="elecFee" class="f-18 font-weight-bold text-warning">0đ</span>
                        </div>
                    </div>

                    <!-- Nước -->
                    <h6 class="mt-4 mb-3 text-info"><i class="feather icon-droplet"></i> Tiền nước</h6>
                    <div class="row align-items-end mb-4">
                        <div class="col-md-4">
                            <div class="form-group mb-md-0">
                                <label class="form-label">Số m³ tiêu thụ</label>
                                <input asp-for="WaterUsage" type="number" step="0.1" placeholder="VD: 12" id="waterUsage" oninput="calcTotal()" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-1 text-center d-none d-md-block">
                            <span class="f-20 text-muted">×</span>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group mb-md-0">
                                <label class="form-label">Đơn giá (đ/m³)</label>
                                <input asp-for="WaterUnitPrice" type="number" step="100" id="waterPrice" oninput="calcTotal()" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-1 text-center d-none d-md-block">
                            <span class="f-20 text-muted">=</span>
                        </div>
                        <div class="col-md-2 text-right">
                            <small class="text-muted d-block">Thành tiền</small>
                            <span id="waterFee" class="f-18 font-weight-bold text-info">0đ</span>
                        </div>
                    </div>

                    <hr>

                    <!-- Phí dịch vụ & Hạn TT -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="ServiceFee" class="form-label">Phí dịch vụ (VNĐ)</label>
                                <input asp-for="ServiceFee" type="number" step="1000" placeholder="VD: 975000" id="serviceFee" oninput="calcTotal()" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="DueDate" class="form-label">Hạn thanh toán</label>
                                <input asp-for="DueDate" type="date" class="form-control" />
                            </div>
                        </div>
                    </div>

                    <!-- Tổng cộng -->
                    <div class="alert alert-primary mt-3 d-flex justify-content-between align-items-center">
                        <span class="f-16 font-weight-bold">Tổng cộng:</span>
                        <span id="totalAmount" class="f-24 font-weight-bold">0đ</span>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary"><i class="feather icon-save"></i> Tạo hóa đơn</button>
                        <a asp-action="Index" class="btn btn-light"><i class="feather icon-arrow-left"></i> Quay lại</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function calcTotal() {
            var eu = parseFloat(document.getElementById('elecUsage').value) || 0;
            var ep = parseFloat(document.getElementById('elecPrice').value) || 0;
            var wu = parseFloat(document.getElementById('waterUsage').value) || 0;
            var wp = parseFloat(document.getElementById('waterPrice').value) || 0;
            var sf = parseFloat(document.getElementById('serviceFee').value) || 0;
            var ef = eu * ep, wf = wu * wp;
            document.getElementById('elecFee').textContent = ef.toLocaleString('vi-VN') + 'đ';
            document.getElementById('waterFee').textContent = wf.toLocaleString('vi-VN') + 'đ';
            document.getElementById('totalAmount').textContent = (ef + wf + sf).toLocaleString('vi-VN') + 'đ';
        }
        calcTotal();
    </script>
}
