@model CreateInvoiceVM
@{
    ViewData["Title"] = "Tạo hóa đơn";
    ViewData["Subtitle"] = "Tạo hóa đơn nước và dịch vụ cho căn hộ";
}

@section Styles {
    <!-- Select2 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <style>
        .select2-container .select2-selection--single {
            height: 43px;
            border: 1px solid #ced4da;
            padding: 6px 12px;
        }
        .select2-container--default .select2-selection--single .select2-selection__arrow {
            height: 41px;
        }
    </style>
}

<div class="row">
    <div class="col-sm-12 col-md-10 col-xl-8">
        <div class="card">
            <div class="card-header">
                <h5>Thông tin hóa đơn</h5>
            </div>
            <div class="card-body">
                @if (ViewData.ModelState.TryGetValue(string.Empty, out var modelState) && modelState.Errors.Any())
                {
                    <div class="alert alert-danger">
                        <div asp-validation-summary="ModelOnly" class="mb-0"></div>
                    </div>
                }

                <form asp-action="Create" method="post" id="invoiceForm">
                    @Html.AntiForgeryToken()

                    <div class="form-group">
                        <label asp-for="ApartmentId" class="form-label">Căn hộ <span class="text-danger">*</span></label>
                        <select asp-for="ApartmentId" class="form-control select2" id="apartmentSelect">
                            <option value="">-- Tìm và chọn căn hộ --</option>
                            @if (ViewBag.ApartmentsList != null)
                            {
                                foreach (var apt in ViewBag.ApartmentsList)
                                {
                                    <option value="@apt.Id" data-area="@apt.Area" selected="@(Model?.ApartmentId == apt.Id)">
                                        @apt.ApartmentNumber - Tầng @apt.Floor (@apt.OwnerName - @apt.Area m²)
                                    </option>
                                }
                            }
                        </select>
                        <span asp-validation-for="ApartmentId" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Month" class="form-label">Tháng <span class="text-danger">*</span></label>
                                <select asp-for="Month" class="form-control">
                                    @for (int m = 1; m <= 12; m++){<option value="@m">Tháng @m</option>}
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Year" class="form-label">Năm <span class="text-danger">*</span></label>
                                <input asp-for="Year" type="number" class="form-control" />
                            </div>
                        </div>
                    </div>



                    <!-- Nước -->
                    <h6 class="mt-4 mb-3 text-info"><i class="feather icon-droplet"></i> Tiền nước</h6>
                    <div class="row align-items-end mb-4">
                        <div class="col-md-4">
                            <div class="form-group mb-md-0">
                                <label class="form-label">Số m³ tiêu thụ</label>
                                <input asp-for="WaterUsage" type="number" step="0.1" placeholder="VD: 12" id="waterUsage" oninput="calcTotal()" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-1 text-center d-none d-md-block">
                            <span class="f-20 text-muted">×</span>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group mb-md-0">
                                <label class="form-label">Đơn giá (đ/m³)</label>
                                <input asp-for="WaterUnitPrice" type="number" step="100" id="waterPrice" oninput="calcTotal()" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-1 text-center d-none d-md-block">
                            <span class="f-20 text-muted">=</span>
                        </div>
                        <div class="col-md-2 text-right">
                            <small class="text-muted d-block">Thành tiền</small>
                            <span id="waterFee" class="f-18 font-weight-bold text-info">0đ</span>
                        </div>
                    </div>

                    <hr>

                    <!-- Phí dịch vụ chi tiết -->
                    <h6 class="mt-4 mb-3 text-primary"><i class="feather icon-settings"></i> Các khoản Phí dịch vụ</h6>
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="ManagementFee" class="form-label">Phí quản lý vận hành (VNĐ) <span class="text-danger">*</span></label>
                                <input asp-for="ManagementFee" type="number" step="1000" id="managementFee" oninput="calcTotal()" class="form-control" />
                                <span asp-validation-for="ManagementFee" class="text-danger small"></span>
                                <small class="text-muted d-block mt-1">Đơn giá: <strong id="managementUnitPrice">@(((decimal)ViewBag.DefaultManagementFeePerM2).ToString("N0"))</strong>đ/m²</small>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="WasteFee" class="form-label">Phí vệ sinh (VNĐ) <span class="text-danger">*</span></label>
                                <input asp-for="WasteFee" type="number" step="1000" id="wasteFee" oninput="calcTotal()" class="form-control" />
                                <span asp-validation-for="WasteFee" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="ParkingFee" class="form-label">Phí gửi xe (VNĐ) <span class="text-danger">*</span></label>
                                <input asp-for="ParkingFee" type="number" step="1000" id="parkingFee" oninput="calcTotal()" class="form-control" />
                                <span asp-validation-for="ParkingFee" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="DueDate" class="form-label">Hạn thanh toán <span class="text-danger">*</span></label>
                                <input asp-for="DueDate" type="date" class="form-control" />
                                <span asp-validation-for="DueDate" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Tổng cộng -->
                    <div class="alert alert-primary mt-3 d-flex justify-content-between align-items-center">
                        <span class="f-16 font-weight-bold">Tổng cộng:</span>
                        <span id="totalAmount" class="f-24 font-weight-bold">0đ</span>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary"><i class="feather icon-save"></i> Tạo hóa đơn</button>
                        <a asp-action="Index" class="btn btn-light"><i class="feather icon-arrow-left"></i> Quay lại</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <!-- Select2 JS -->
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        $(document).ready(function() {
            $('.select2').select2({
                placeholder: "-- Tìm và chọn căn hộ --",
                allowClear: true,
                width: '100%'
            });

            // Khi thay đổi căn hộ -> tính động phí quản lý
            $('#apartmentSelect').on('change', function() {
                var selectedOption = $(this).find('option:selected');
                var area = parseFloat(selectedOption.data('area')) || 0;
                var unitPrice = parseFloat('@ViewBag.DefaultManagementFeePerM2') || 10000;
                
                if (area > 0) {
                    var mFee = area * unitPrice;
                    document.getElementById('managementFee').value = mFee;
                } else {
                    document.getElementById('managementFee').value = 0;
                }
                calcTotal();
            });
        });

        function calcTotal() {
            var wu = parseFloat(document.getElementById('waterUsage').value) || 0;
            var wp = parseFloat(document.getElementById('waterPrice').value) || 0;
            var mFee = parseFloat(document.getElementById('managementFee').value) || 0;
            var wFeeInput = parseFloat(document.getElementById('wasteFee').value) || 0;
            var pFee = parseFloat(document.getElementById('parkingFee').value) || 0;
            
            var wf = wu * wp;
            var sf = mFee + wFeeInput + pFee;
            
            document.getElementById('waterFee').textContent = wf.toLocaleString('vi-VN') + 'đ';
            document.getElementById('totalAmount').textContent = (wf + sf).toLocaleString('vi-VN') + 'đ';
        }
        calcTotal();
    </script>
}
