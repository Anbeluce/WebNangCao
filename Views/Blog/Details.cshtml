@model WebNangCao.Models.BlogPost
@{
    ViewData["Title"] = Model.Title;
}

<div class="row justify-content-center">
    <div class="col-md-10 col-lg-8">
        <div class="card">
            <div class="card-body">
                <div class="mb-4 text-center">
                    <h2 class="font-weight-bold">@Model.Title</h2>
                    <div class="text-muted mt-3">
                        <span class="mr-3"><i class="feather icon-calendar"></i> @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                        <span><i class="feather icon-user"></i> Đăng bởi: @(Model.Author?.FullName ?? "Ban quản lý")</span>
                    </div>
                </div>
                
                <hr />

                <div class="blog-content mt-4" style="line-height: 1.8; font-size: 1.05rem;">
                    @Html.Raw(Model.Content)
                </div>

                <div class="mt-5 pt-3 border-top">
                    <a asp-action="Index" class="btn btn-light"><i class="feather icon-arrow-left"></i> Quay lại danh sách tin tức</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .blog-content img {
            max-width: 100%;
            height: auto;
            border-radius: 8px;
            margin: 15px 0;
        }
        .blog-content h1, .blog-content h2, .blog-content h3 {
            margin-top: 1.5rem;
            margin-bottom: 1rem;
        }
        .blog-content p {
            margin-bottom: 1rem;
        }
    </style>
}
