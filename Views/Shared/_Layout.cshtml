<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Chung cư Smart</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        :root {
            --accent: #667eea;
            --accent2: #764ba2;
            --body-bg: #0f1117;
            --card-bg: #1a1d27;
            --border: rgba(255,255,255,0.08);
        }

        * { box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--body-bg);
            color: #e2e8f0;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Navbar */
        .main-navbar {
            background: rgba(15, 17, 23, 0.95);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border);
            padding: 0 28px;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .nav-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }

        .nav-brand .brand-icon {
            width: 32px;
            height: 32px;
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
        }

        .nav-brand .brand-name {
            font-size: 16px;
            font-weight: 700;
            color: #fff;
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .nav-link-main {
            padding: 7px 14px;
            border-radius: 8px;
            color: rgba(255,255,255,0.6);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.2s;
        }

        .nav-link-main:hover {
            background: rgba(255,255,255,0.07);
            color: #fff;
        }

        .nav-auth {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .btn-login-nav {
            padding: 7px 18px;
            background: rgba(102,126,234,0.15);
            border: 1px solid rgba(102,126,234,0.3);
            border-radius: 8px;
            color: #a5b4fc;
            text-decoration: none;
            font-size: 13px;
            font-weight: 600;
            transition: all 0.2s;
        }

        .btn-login-nav:hover {
            background: rgba(102,126,234,0.25);
            color: #fff;
        }

        .btn-register-nav {
            padding: 7px 18px;
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            border: none;
            border-radius: 8px;
            color: #fff;
            text-decoration: none;
            font-size: 13px;
            font-weight: 600;
            transition: all 0.2s;
        }

        .btn-register-nav:hover {
            color: #fff;
            opacity: 0.9;
        }

        .user-menu {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .user-chip {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 5px 12px;
            background: rgba(255,255,255,0.06);
            border: 1px solid var(--border);
            border-radius: 20px;
            font-size: 13px;
            color: rgba(255,255,255,0.75);
        }

        .user-chip .user-dot {
            width: 26px;
            height: 26px;
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
        }

        .btn-logout-nav {
            padding: 6px 14px;
            background: rgba(239,68,68,0.1);
            border: 1px solid rgba(239,68,68,0.2);
            border-radius: 8px;
            color: #fca5a5;
            font-size: 13px;
            cursor: pointer;
            font-family: 'Inter', sans-serif;
            transition: all 0.2s;
        }

        .btn-logout-nav:hover {
            background: rgba(239,68,68,0.2);
            color: #fff;
        }

        .btn-admin-nav {
            padding: 6px 14px;
            background: rgba(102,126,234,0.12);
            border: 1px solid rgba(102,126,234,0.25);
            border-radius: 8px;
            color: #a5b4fc;
            text-decoration: none;
            font-size: 12px;
            font-weight: 600;
        }

        .btn-admin-nav:hover { color: #fff; }

        /* Main content */
        main {
            flex: 1;
            padding: 32px 28px;
            max-width: 1200px;
            width: 100%;
            margin: 0 auto;
        }

        footer {
            background: rgba(255,255,255,0.02);
            border-top: 1px solid var(--border);
            padding: 16px 28px;
            text-align: center;
            font-size: 12px;
            color: rgba(255,255,255,0.25);
        }

        /* Toast alerts */
        .toast-success {
            background: rgba(34,197,94,0.12);
            border: 1px solid rgba(34,197,94,0.25);
            color: #86efac;
            border-radius: 12px;
            padding: 12px 16px;
            font-size: 13px;
            margin-bottom: 20px;
        }

        /* Fix dropdown/select dark theme */
        select, select option {
            background-color: #1a1d27 !important;
            color: #e2e8f0 !important;
        }

        select option:checked {
            background-color: #2d3148 !important;
        }

        input, select, textarea {
            color-scheme: dark;
        }
    </style>
</head>
<body>
    <nav class="main-navbar">
        <a class="nav-brand" asp-area="" asp-controller="Home" asp-action="Index">
            <div class="brand-icon">🏢</div>
            <span class="brand-name">Chung cư Smart</span>
        </a>

        <div class="nav-links">
            <a class="nav-link-main" asp-area="" asp-controller="Home" asp-action="Index">🏠 Trang chủ</a>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a class="nav-link-main" asp-area="" asp-controller="Blog" asp-action="Index">📰 Tin tức</a>
                <a class="nav-link-main" asp-area="" asp-controller="Resident" asp-action="Index">📄 Hóa đơn</a>
                <a class="nav-link-main" asp-area="" asp-controller="Resident" asp-action="Profile">👤 Tài khoản</a>
            }
        </div>

        <div class="nav-auth">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="user-menu">
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="btn-admin-nav">
                            ⚙️ Admin
                        </a>
                    }
                    <div class="user-chip">
                        <div class="user-dot">👤</div>
                        <span>@(User.Identity.Name?.Split('@')[0])</span>
                    </div>
                    <form asp-action="Logout" asp-controller="Auth" asp-area="" method="post" style="margin:0;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-logout-nav">Đăng xuất</button>
                    </form>
                </div>
            }
            else
            {
                <a asp-action="Login" asp-controller="Auth" class="btn-login-nav">Đăng nhập</a>
                <a asp-action="Register" asp-controller="Auth" class="btn-register-nav">Đăng ký</a>
            }
        </div>
    </nav>

    <main role="main">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="toast-success">✅ @TempData["SuccessMessage"]</div>
        }
        @RenderBody()
    </main>

    <footer>
        <span>© 2026 Chung cư Smart — Hệ thống quản lý chung cư thông minh</span>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
