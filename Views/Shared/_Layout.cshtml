<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=0, minimal-ui">
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <title>@ViewData["Title"] - Chung cư Smart</title>

    <!-- Favicon icon -->
    <link rel="icon" href="~/images/favicon.ico" type="image/x-icon">
    <!-- fontawesome icon -->
    <link rel="stylesheet" href="~/fonts/fontawesome/css/fontawesome-all.min.css">
    <!-- animation css -->
    <link rel="stylesheet" href="~/plugins/animation/css/animate.min.css">
    <!-- vendor css -->
    <link rel="stylesheet" href="~/css/style.css">
    
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body, h1, h2, h3, h4, h5, h6, input, button, select, textarea, .h1, .h2, .h3, .h4, .h5, .h6 {
            font-family: 'Inter', sans-serif !important;
        }
        /* Fix validation error color */
        .field-validation-error { color: #dc3545; font-size: 80%; mt-1; }
        .input-validation-error { border-color: #dc3545; }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
    <!-- [ Pre-loader ] start -->
    <div class="loader-bg">
        <div class="loader-track">
            <div class="loader-fill"></div>
        </div>
    </div>
    <!-- [ Pre-loader ] End -->

    <!-- [ navigation menu ] start -->
    <nav class="pcoded-navbar menupos-fixed">
        <div class="navbar-wrapper">
            <div class="navbar-brand header-logo">
                <a asp-area="" asp-controller="Blog" asp-action="Index" class="b-brand">
                    <div class="b-bg">
                        <i class="feather icon-home"></i>
                    </div>
                    <span class="b-title">Chung cư Smart</span>
                </a>
                <a class="mobile-menu" id="mobile-collapse" href="#!"><span></span></a>
            </div>
            <div class="navbar-content scroll-div">
                <ul class="nav pcoded-inner-navbar">
                    <li class="nav-item pcoded-menu-caption">
                        <label>Menu</label>
                    </li>
                    <li class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Blog" ? "active" : "")">
                        <a asp-area="" asp-controller="Blog" asp-action="Index" class="nav-link">
                            <span class="pcoded-micon"><i class="feather icon-file-text"></i></span>
                            <span class="pcoded-mtext">Tin tức</span>
                        </a>
                    </li>
                    
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Resident" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                            <a asp-area="" asp-controller="Resident" asp-action="Index" class="nav-link">
                                <span class="pcoded-micon"><i class="feather icon-clipboard"></i></span>
                                <span class="pcoded-mtext">Hóa đơn</span>
                            </a>
                        </li>
                        <li class="nav-item pcoded-menu-caption">
                            <label>Tài khoản</label>
                        </li>
                        <li class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Resident" && ViewContext.RouteData.Values["action"]?.ToString() == "Profile" ? "active" : "")">
                            <a asp-area="" asp-controller="Resident" asp-action="Profile" class="nav-link">
                                <span class="pcoded-micon"><i class="feather icon-user"></i></span>
                                <span class="pcoded-mtext">Hồ sơ cá nhân</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="#" onclick="document.getElementById('logoutFormSidebar').submit(); return false;" class="nav-link">
                                <span class="pcoded-micon"><i class="feather icon-log-out"></i></span>
                                <span class="pcoded-mtext">Đăng xuất</span>
                            </a>
                            <form asp-action="Logout" asp-controller="Auth" asp-area="" method="post" id="logoutFormSidebar" style="display:none;">
                                @Html.AntiForgeryToken()
                            </form>
                        </li>
                    }
                    
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item pcoded-menu-caption">
                            <label>Hệ thống</label>
                        </li>
                        <li class="nav-item">
                            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="nav-link">
                                <span class="pcoded-micon"><i class="feather icon-settings"></i></span>
                                <span class="pcoded-mtext">Admin Panel</span>
                            </a>
                        </li>
                    }

                </ul>
            </div>
        </div>
    </nav>
    <!-- [ navigation menu ] end -->

    <!-- [ Header removed - all features in sidebar ] -->

    <!-- [ Main Content ] start -->
    <div class="pcoded-main-container">
        <div class="pcoded-wrapper">
            <div class="pcoded-content">
                <div class="pcoded-inner-content">
                    <div class="main-body">
                        <div class="page-wrapper">
                            <!-- [ breadcrumb ] start -->
                            <div class="page-header">
                                <div class="page-block">
                                    <div class="row align-items-center">
                                        <div class="col-md-12">
                                            <ul class="breadcrumb">
                                                <li class="breadcrumb-item"><a asp-area="" asp-controller="Blog" asp-action="Index"><i class="feather icon-home"></i></a></li>
                                                <li class="breadcrumb-item"><a href="#!">@ViewContext.RouteData.Values["controller"]?.ToString()</a></li>
                                            </ul>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- [ breadcrumb ] end -->
                            
                            <!-- [ Main Content ] start -->
                            <div class="row">
                                <div class="col-sm-12">
                                    @if (TempData["SuccessMessage"] != null)
                                    {
                                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                                            @TempData["SuccessMessage"]
                                            <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                                        </div>
                                    }
                                    @if (TempData["ErrorMessage"] != null)
                                    {
                                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                            @TempData["ErrorMessage"]
                                            <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                                        </div>
                                    }

                                    @RenderBody()
                                </div>
                            </div>
                            <!-- [ Main Content ] end -->
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- [ Main Content ] end -->

    <!-- Required Js -->
    <script src="~/js/vendor-all.min.js"></script>
    <script src="~/plugins/bootstrap/js/bootstrap.min.js"></script>
    <script src="~/js/pcoded.min.js"></script>
    
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
