<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=0, minimal-ui">
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <title>@ViewData["Title"] - Chung cư Smart</title>

    <!-- Favicon icon -->
    <link rel="icon" href="~/images/favicon.ico" type="image/x-icon">
    <!-- fontawesome icon -->
    <link rel="stylesheet" href="~/fonts/fontawesome/css/fontawesome-all.min.css">
    <!-- animation css -->
    <link rel="stylesheet" href="~/plugins/animation/css/animate.min.css">
    <!-- vendor css -->
    <link rel="stylesheet" href="~/css/style.css">

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Inter', sans-serif !important;
            background: #f4f7fa;
            min-height: 100vh;
        }

        .guest-navbar {
            background: #fff;
            border-bottom: 1px solid #e8e8e8;
            padding: 0 30px;
            height: 65px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: fixed;
            top: 0; left: 0; right: 0;
            z-index: 1030;
        }
        .guest-navbar .brand {
            display: flex; align-items: center;
            text-decoration: none; gap: 10px;
        }
        .guest-navbar .brand-icon {
            width: 36px; height: 36px;
            background: #04a9f5;
            display: flex; align-items: center; justify-content: center;
            color: #fff; font-size: 16px;
        }
        .guest-navbar .brand-text {
            font-size: 1.15rem; font-weight: 700; color: #111;
        }
        .guest-navbar .nav-links {
            display: flex; align-items: center; gap: 0;
            list-style: none; margin: 0; padding: 0;
        }
        .guest-navbar .nav-links a.nav-link-item {
            color: #666; text-decoration: none;
            padding: 10px 16px; font-weight: 600;
            font-size: 0.85rem; letter-spacing: 0.5px;
            text-transform: uppercase; transition: color 0.2s;
        }
        .guest-navbar .nav-links a.nav-link-item:hover,
        .guest-navbar .nav-links a.nav-link-item.active {
            color: #04a9f5;
        }
        .guest-navbar .auth-buttons {
            display: flex; align-items: center; gap: 8px;
        }
        .guest-navbar .btn-login {
            padding: 8px 20px; border: 2px solid #04a9f5; color: #04a9f5;
            font-weight: 600; text-decoration: none; font-size: 0.8rem;
            text-transform: uppercase; letter-spacing: 1px; transition: all 0.2s;
        }
        .guest-navbar .btn-login:hover { background: #04a9f5; color: #fff; }
        .guest-navbar .btn-register {
            padding: 8px 20px; background: #04a9f5; color: #fff;
            font-weight: 600; text-decoration: none; font-size: 0.8rem;
            text-transform: uppercase; letter-spacing: 1px;
            border: 2px solid #04a9f5; transition: all 0.2s;
        }
        .guest-navbar .btn-register:hover { background: transparent; color: #04a9f5; }

        .guest-main {
            padding-top: 85px;
            padding-bottom: 40px;
            min-height: 100vh;
        }

        .guest-footer {
            text-align: center;
            padding: 25px 20px;
            color: #999;
            font-size: 0.85rem;
            border-top: 1px solid #e8e8e8;
            background: #fff;
        }
        .guest-footer a { color: #04a9f5; text-decoration: none; }

        @@media (max-width: 768px) {
            .guest-navbar { padding: 0 15px; }
            .guest-navbar .nav-links { display: none; }
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
    <!-- [ Guest Navbar ] start -->
    <div class="guest-navbar">
        <a asp-area="" asp-controller="Home" asp-action="Index" class="brand">
            <div class="brand-icon"><i class="feather icon-home"></i></div>
            <span class="brand-text">Chung cư Smart</span>
        </a>

        <ul class="nav-links">
            <li>
                <a asp-area="" asp-controller="Home" asp-action="Index"
                   class="nav-link-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                    Trang chủ
                </a>
            </li>
            <li>
                <a asp-area="" asp-controller="Blog" asp-action="Index"
                   class="nav-link-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Blog" ? "active" : "")">
                    Tin tức
                </a>
            </li>
        </ul>

        <div class="auth-buttons">
            <a asp-area="" asp-controller="Auth" asp-action="Login" class="btn-login">Đăng nhập</a>
            <a asp-area="" asp-controller="Auth" asp-action="Register" class="btn-register">Đăng ký</a>
        </div>
    </div>
    <!-- [ Guest Navbar ] end -->

    <!-- [ Main Content ] start -->
    <div class="guest-main">
        <div class="container">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["ErrorMessage"]
                    <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                </div>
            }

            @RenderBody()
        </div>
    </div>
    <!-- [ Main Content ] end -->

    <!-- [ Footer ] start -->
    <div class="guest-footer">
        <p>&copy; @DateTime.UtcNow.AddHours(7).Year Chung cư Smart. Hệ thống quản lý chung cư thông minh.</p>
    </div>
    <!-- [ Footer ] end -->

    <!-- Required Js -->
    <script src="~/js/vendor-all.min.js"></script>
    <script src="~/plugins/bootstrap/js/bootstrap.min.js"></script>

    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
