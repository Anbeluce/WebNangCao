@model WebNangCao.Models.ViewModels.ChangePasswordVM
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

@section Styles {
    <style>
        .change-pass-card {
            border-radius: 12px !important;
            border: none !important;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05) !important;
        }
        .form-control:focus {
            border-color: #04a9f5 !important;
            box-shadow: 0 0 0 0.2rem rgba(4, 169, 245, 0.15) !important;
        }
    </style>
}

<div class="row justify-content-center">
    <div class="col-sm-12 col-md-8 col-lg-6 col-xl-5">
        <div class="card change-pass-card">
            <div class="card-header bg-white border-bottom py-3">
                <h5 class="font-weight-bold text-dark mb-0"><i class="feather icon-lock mr-2 text-primary"></i>Thay đổi mật khẩu tài khoản</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="ChangePassword" method="post">
                    @Html.AntiForgeryToken()
                    
                    <div class="form-group mb-4">
                        <label asp-for="CurrentPassword" class="form-label font-weight-bold text-muted small">Mật khẩu hiện tại <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text bg-light border-right-0"><i class="feather icon-shield text-muted"></i></span>
                            </div>
                            <input asp-for="CurrentPassword" class="form-control" style="border-top-left-radius: 0; border-bottom-left-radius: 0;" />
                        </div>
                        <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                    </div>
                    
                    <div class="form-group mb-4">
                        <label asp-for="NewPassword" class="form-label font-weight-bold text-muted small">Mật khẩu mới <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text bg-light border-right-0"><i class="feather icon-key text-muted"></i></span>
                            </div>
                            <input asp-for="NewPassword" class="form-control" style="border-top-left-radius: 0; border-bottom-left-radius: 0;" />
                        </div>
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>
                    
                    <div class="form-group mb-4">
                        <label asp-for="ConfirmPassword" class="form-label font-weight-bold text-muted small">Xác nhận mật khẩu mới <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text bg-light border-right-0"><i class="feather icon-check-circle text-muted"></i></span>
                            </div>
                            <input asp-for="ConfirmPassword" class="form-control" style="border-top-left-radius: 0; border-bottom-left-radius: 0;" />
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>
                    
                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary w-100 py-2 font-weight-bold shadow-sm mb-3" style="border-radius: 8px;">
                            <i class="feather icon-save mr-1"></i> Xác nhận đổi mật khẩu
                        </button>
                        
                        <a asp-action="Profile" class="btn btn-light w-100 py-2 font-weight-bold" style="border-radius: 8px;">
                            <i class="feather icon-arrow-left mr-1"></i> Quay về trang hồ sơ
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
