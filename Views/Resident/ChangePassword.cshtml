@model WebNangCao.Models.ViewModels.ChangePasswordVM
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="row justify-content-center">
    <div class="col-sm-12 col-md-8 col-lg-6 col-xl-5">
        <div class="card">
            <div class="card-header">
                <h5>Đổi mật khẩu tài khoản</h5>
            </div>
            <div class="card-body">
                <form asp-action="ChangePassword" method="post">
                    @Html.AntiForgeryToken()
                    
                    <div class="form-group mb-4">
                        <label asp-for="CurrentPassword" class="font-weight-bold small"></label>
                        <input asp-for="CurrentPassword" class="form-control" />
                        <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                    </div>
                    
                    <div class="form-group mb-4">
                        <label asp-for="NewPassword" class="font-weight-bold small"></label>
                        <input asp-for="NewPassword" class="form-control" />
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>
                    
                    <div class="form-group mb-4">
                        <label asp-for="ConfirmPassword" class="font-weight-bold small"></label>
                        <input asp-for="ConfirmPassword" class="form-control" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>
                    
                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary btn-block">
                            <i class="feather icon-lock mr-1"></i> Xác nhận đổi mật khẩu
                        </button>
                        
                        <a asp-action="Profile" class="btn btn-light btn-block mt-2">
                            <i class="feather icon-arrow-left mr-1"></i> Quay lại hồ sơ
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
