@model WebNangCao.Models.ViewModels.ChangePasswordVM
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card">
            <div class="card-header border-bottom">
                <h5>Đổi mật khẩu</h5>
            </div>
            <div class="card-body">
                <form asp-action="ChangePassword" method="post">
                    @Html.AntiForgeryToken()
                    
                    <div class="form-group mb-4">
                        <label asp-for="CurrentPassword" class="form-label"></label>
                        <input asp-for="CurrentPassword" class="form-control" />
                        <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                    </div>
                    
                    <div class="form-group mb-4">
                        <label asp-for="NewPassword" class="form-label"></label>
                        <input asp-for="NewPassword" class="form-control" />
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>
                    
                    <div class="form-group mb-4">
                        <label asp-for="ConfirmPassword" class="form-label"></label>
                        <input asp-for="ConfirmPassword" class="form-control" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>
                    
                    <button type="submit" class="btn btn-warning w-100 mt-2">
                        <i class="feather icon-lock"></i> Xác nhận đổi mật khẩu
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
