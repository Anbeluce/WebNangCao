@model List<WebNangCao.Models.Apartment>
@{
    ViewData["Title"] = "Tổng quan";
}

<!-- Chào mừng -->
<div class="row mb-4">
    <div class="col-sm-12">
        <h2 class="mb-2">Xin chào, @ViewBag.UserName</h2>
        <p class="text-muted">Quản lý căn hộ và hóa đơn của bạn</p>
    </div>
</div>

<!-- Thống kê nhanh -->
<div class="row">
    <div class="col-md-6 col-xl-3">
        <div class="card bg-c-blue order-card">
            <div class="card-body">
                <h6 class="text-white">Căn hộ sở hữu</h6>
                <h2 class="text-white">@ViewBag.TotalApartments</h2>
                <i class="feather icon-home card-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card bg-c-green order-card">
            <div class="card-body">
                <h6 class="text-white">Tổng số hóa đơn</h6>
                <h2 class="text-white">@ViewBag.TotalInvoices</h2>
                <i class="feather icon-file-text card-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card bg-c-red order-card">
            <div class="card-body">
                <h6 class="text-white">Chưa thanh toán</h6>
                <h2 class="text-white">@ViewBag.UnpaidInvoices</h2>
                <i class="feather icon-alert-circle card-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card bg-c-yellow order-card">
            <div class="card-body">
                <h6 class="text-white">Số tiền còn nợ</h6>
                <h2 class="text-white">@(((decimal)ViewBag.TotalUnpaid).ToString("N0"))đ</h2>
                <i class="feather icon-credit-card card-icon"></i>
            </div>
        </div>
    </div>
</div>

<!-- Danh sách căn hộ -->
<div class="row mb-3 mt-2">
    <div class="col-12">
        <h4><i class="feather icon-home text-primary mr-2"></i>Căn hộ của bạn</h4>
        <hr>
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="row">
        <div class="col-12">
            <div class="card text-center">
                <div class="card-body py-5">
                    <i class="feather icon-home display-3 text-muted mb-3 d-block"></i>
                    <h5 class="text-muted">Bạn chưa được gán căn hộ nào.</h5>
                    <p class="text-muted mb-0">Vui lòng liên hệ ban quản lý để được hỗ trợ.</p>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="row">
        @foreach (var apt in Model)
        {
            var unpaid = apt.Invoices.Count(i => i.Status == WebNangCao.Models.InvoiceStatus.Unpaid);
            var totalDebt = apt.Invoices.Where(i => i.Status != WebNangCao.Models.InvoiceStatus.Paid).Sum(i => i.TotalAmount);

            <div class="col-xl-4 col-md-6">
                <div class="card user-card user-card-1">
                    <div class="card-body pt-0">
                        <div class="user-about-block text-center mt-4">
                            <div class="row align-items-end">
                                <div class="col text-center">
                                    <div class="bg-primary text-white d-inline-flex align-items-center justify-content-center" style="width: 60px; height: 60px; border-radius: 50%; font-size: 24px;">
                                        <i class="feather icon-home"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="text-center mt-3">
                            <h4 class="mb-1">@apt.ApartmentNumber</h4>
                            <p class="mb-3 text-muted">Tầng @apt.Floor • @apt.Area m²</p>
                        </div>
                        
                        <hr>

                        <div class="row text-center mt-3">
                            <div class="col-4">
                                <h6 class="mb-1">@apt.Invoices.Count</h6>
                                <p class="text-muted mb-0">Hóa đơn</p>
                            </div>
                            <div class="col-4 border-left">
                                <h6 class="mb-1 @(unpaid > 0 ? "text-danger" : "text-success")">@unpaid</h6>
                                <p class="text-muted mb-0">Chưa thanh toán</p>
                            </div>
                            <div class="col-4 border-left">
                                <h6 class="mb-1 @(totalDebt > 0 ? "text-warning" : "text-success")">@totalDebt.ToString("N0")</h6>
                                <p class="text-muted mb-0">Còn nợ</p>
                            </div>
                        </div>

                        <div class="mt-4">
                            <a asp-action="Invoices" asp-route-id="@apt.Id" class="btn btn-outline-primary btn-block">
                                <i class="feather icon-file-text"></i> Xem hóa đơn
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
