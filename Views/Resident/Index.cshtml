@model List<WebNangCao.Models.Apartment>
@{
    ViewData["Title"] = "Tài khoản cư dân";
}

<!-- Chào mừng -->
<div style="margin-bottom:28px;">
    <h2 style="font-size:24px; font-weight:700; color:#fff; margin:0;">
        Xin chào, @ViewBag.UserName 👋
    </h2>
    <p style="font-size:14px; color:rgba(255,255,255,0.5); margin:4px 0 0;">
        Quản lý căn hộ và hóa đơn của bạn
    </p>
</div>

<!-- Thống kê nhanh -->
<div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(200px, 1fr)); gap:16px; margin-bottom:28px;">
    <div style="background:var(--card-bg, #1a1d27); border:1px solid rgba(255,255,255,0.08); border-radius:14px; padding:20px;">
        <div style="font-size:12px; color:rgba(255,255,255,0.45); text-transform:uppercase; letter-spacing:0.5px; margin-bottom:8px;">Căn hộ</div>
        <div style="font-size:28px; font-weight:700; color:#fff;">@ViewBag.TotalApartments</div>
    </div>
    <div style="background:var(--card-bg, #1a1d27); border:1px solid rgba(255,255,255,0.08); border-radius:14px; padding:20px;">
        <div style="font-size:12px; color:rgba(255,255,255,0.45); text-transform:uppercase; letter-spacing:0.5px; margin-bottom:8px;">Tổng hóa đơn</div>
        <div style="font-size:28px; font-weight:700; color:#fff;">@ViewBag.TotalInvoices</div>
    </div>
    <div style="background:var(--card-bg, #1a1d27); border:1px solid rgba(255,255,255,0.08); border-radius:14px; padding:20px;">
        <div style="font-size:12px; color:rgba(255,255,255,0.45); text-transform:uppercase; letter-spacing:0.5px; margin-bottom:8px;">Chưa thanh toán</div>
        <div style="font-size:28px; font-weight:700; color:#f87171;">@ViewBag.UnpaidInvoices</div>
    </div>
    <div style="background:var(--card-bg, #1a1d27); border:1px solid rgba(255,255,255,0.08); border-radius:14px; padding:20px;">
        <div style="font-size:12px; color:rgba(255,255,255,0.45); text-transform:uppercase; letter-spacing:0.5px; margin-bottom:8px;">Số tiền còn nợ</div>
        <div style="font-size:28px; font-weight:700; color:#fbbf24;">@(((decimal)ViewBag.TotalUnpaid).ToString("N0"))đ</div>
    </div>
</div>

<!-- Danh sách căn hộ -->
<h3 style="font-size:16px; font-weight:600; color:#fff; margin-bottom:16px;">🏠 Căn hộ của bạn</h3>

@if (Model.Count == 0)
{
    <div style="background:var(--card-bg, #1a1d27); border:1px solid rgba(255,255,255,0.08); border-radius:14px; padding:40px; text-align:center;">
        <div style="font-size:48px; margin-bottom:12px;">🏠</div>
        <p style="color:rgba(255,255,255,0.5); font-size:14px;">Bạn chưa được gán căn hộ nào.</p>
        <p style="color:rgba(255,255,255,0.35); font-size:13px;">Vui lòng liên hệ ban quản lý để được hỗ trợ.</p>
    </div>
}
else
{
    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(320px, 1fr)); gap:16px;">
        @foreach (var apt in Model)
        {
            var unpaid = apt.Invoices.Count(i => i.Status == WebNangCao.Models.InvoiceStatus.Unpaid);
            var totalDebt = apt.Invoices.Where(i => i.Status != WebNangCao.Models.InvoiceStatus.Paid).Sum(i => i.TotalAmount);

            <div style="background:var(--card-bg, #1a1d27); border:1px solid rgba(255,255,255,0.08); border-radius:14px; padding:24px; transition:border-color 0.2s;"
                 onmouseover="this.style.borderColor='rgba(102,126,234,0.4)'"
                 onmouseout="this.style.borderColor='rgba(255,255,255,0.08)'">
                
                <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:16px;">
                    <div>
                        <div style="font-size:20px; font-weight:700; color:#fff;">@apt.ApartmentNumber</div>
                        <div style="font-size:13px; color:rgba(255,255,255,0.45); margin-top:2px;">Tầng @apt.Floor • @apt.Area m²</div>
                    </div>
                    <div style="background:linear-gradient(135deg,#667eea,#764ba2); width:40px; height:40px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:18px;">
                        🏠
                    </div>
                </div>

                <div style="display:flex; gap:16px; margin-bottom:16px;">
                    <div style="flex:1; background:rgba(255,255,255,0.04); border-radius:10px; padding:12px;">
                        <div style="font-size:11px; color:rgba(255,255,255,0.4); margin-bottom:4px;">Hóa đơn</div>
                        <div style="font-size:16px; font-weight:600; color:#fff;">@apt.Invoices.Count</div>
                    </div>
                    <div style="flex:1; background:rgba(255,255,255,0.04); border-radius:10px; padding:12px;">
                        <div style="font-size:11px; color:rgba(255,255,255,0.4); margin-bottom:4px;">Chưa thanh toán</div>
                        <div style="font-size:16px; font-weight:600; color:@(unpaid > 0 ? "#f87171" : "#4ade80");">@unpaid</div>
                    </div>
                    <div style="flex:1; background:rgba(255,255,255,0.04); border-radius:10px; padding:12px;">
                        <div style="font-size:11px; color:rgba(255,255,255,0.4); margin-bottom:4px;">Còn nợ</div>
                        <div style="font-size:16px; font-weight:600; color:@(totalDebt > 0 ? "#fbbf24" : "#4ade80");">@totalDebt.ToString("N0")đ</div>
                    </div>
                </div>

                <a asp-action="Invoices" asp-route-id="@apt.Id"
                   style="display:block; text-align:center; padding:10px; background:rgba(102,126,234,0.12); border:1px solid rgba(102,126,234,0.25); border-radius:10px; color:#a5b4fc; text-decoration:none; font-size:13px; font-weight:600; transition:all 0.2s;"
                   onmouseover="this.style.background='rgba(102,126,234,0.25)'; this.style.color='#fff'"
                   onmouseout="this.style.background='rgba(102,126,234,0.12)'; this.style.color='#a5b4fc'">
                    📄 Xem hóa đơn
                </a>
            </div>
        }
    </div>
}
