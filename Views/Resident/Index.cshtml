@model List<WebNangCao.Models.Apartment>
@{
    ViewData["Title"] = "Tổng quan";
}

<!-- Chào mừng -->
<div class="row mb-4">
    <div class="col-sm-12">
        <h2 class="mb-2">Xin chào, @ViewBag.UserName 👋</h2>
        <p class="text-muted">Quản lý căn hộ và hóa đơn của bạn</p>
    </div>
</div>

<!-- Thống kê nhanh -->
<div class="row">
    <div class="col-xl-3 col-md-6">
        <div class="card">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-8">
                        <h4 class="text-c-blue">@ViewBag.TotalApartments</h4>
                        <h6 class="text-muted m-b-0">Căn hộ</h6>
                    </div>
                    <div class="col-4 text-right">
                        <i class="feather icon-layout f-28 text-c-blue"></i>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-c-blue">
                <div class="row align-items-center">
                    <div class="col-9">
                        <p class="text-white m-b-0">Tổng số căn hộ sở hữu</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-xl-3 col-md-6">
        <div class="card">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-8">
                        <h4 class="text-c-green">@ViewBag.TotalInvoices</h4>
                        <h6 class="text-muted m-b-0">Tổng hóa đơn</h6>
                    </div>
                    <div class="col-4 text-right">
                        <i class="feather icon-file-text f-28 text-c-green"></i>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-c-green">
                <div class="row align-items-center">
                    <div class="col-9">
                        <p class="text-white m-b-0">Tất cả hóa đơn</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-xl-3 col-md-6">
        <div class="card">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-8">
                        <h4 class="text-c-red">@ViewBag.UnpaidInvoices</h4>
                        <h6 class="text-muted m-b-0">Chưa thanh toán</h6>
                    </div>
                    <div class="col-4 text-right">
                        <i class="feather icon-alert-triangle f-28 text-c-red"></i>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-c-red">
                <div class="row align-items-center">
                    <div class="col-9">
                        <p class="text-white m-b-0">Cần thanh toán</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-xl-3 col-md-6">
        <div class="card">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-8">
                        <h4 class="text-c-yellow">@(((decimal)ViewBag.TotalUnpaid).ToString("N0"))đ</h4>
                        <h6 class="text-muted m-b-0">Số tiền còn nợ</h6>
                    </div>
                    <div class="col-4 text-right">
                        <i class="feather icon-credit-card f-28 text-c-yellow"></i>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-c-yellow">
                <div class="row align-items-center">
                    <div class="col-9">
                        <p class="text-white m-b-0">Tổng nợ hiện tại</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Danh sách căn hộ -->
<div class="row mb-3 mt-2">
    <div class="col-12">
        <h4>🏠 Căn hộ của bạn</h4>
        <hr>
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="row">
        <div class="col-12">
            <div class="card text-center">
                <div class="card-body py-5">
                    <i class="feather icon-home display-3 text-muted mb-3 d-block"></i>
                    <h5 class="text-muted">Bạn chưa được gán căn hộ nào.</h5>
                    <p class="text-muted mb-0">Vui lòng liên hệ ban quản lý để được hỗ trợ.</p>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="row">
        @foreach (var apt in Model)
        {
            var unpaid = apt.Invoices.Count(i => i.Status == WebNangCao.Models.InvoiceStatus.Unpaid);
            var totalDebt = apt.Invoices.Where(i => i.Status != WebNangCao.Models.InvoiceStatus.Paid).Sum(i => i.TotalAmount);

            <div class="col-xl-4 col-md-6">
                <div class="card user-card user-card-1">
                    <div class="card-body pt-0">
                        <div class="user-about-block text-center mt-4">
                            <div class="row align-items-end">
                                <div class="col text-center">
                                    <div class="bg-primary text-white d-inline-flex align-items-center justify-content-center" style="width: 60px; height: 60px; border-radius: 50%; font-size: 24px;">
                                        <i class="feather icon-home"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="text-center mt-3">
                            <h4 class="mb-1">@apt.ApartmentNumber</h4>
                            <p class="mb-3 text-muted">Tầng @apt.Floor • @apt.Area m²</p>
                        </div>
                        
                        <hr>

                        <div class="row text-center mt-3">
                            <div class="col-4">
                                <h6 class="mb-1">@apt.Invoices.Count</h6>
                                <p class="text-muted mb-0">Hóa đơn</p>
                            </div>
                            <div class="col-4 border-left">
                                <h6 class="mb-1 @(unpaid > 0 ? "text-danger" : "text-success")">@unpaid</h6>
                                <p class="text-muted mb-0">Chưa thanh toán</p>
                            </div>
                            <div class="col-4 border-left">
                                <h6 class="mb-1 @(totalDebt > 0 ? "text-warning" : "text-success")">@totalDebt.ToString("N0")</h6>
                                <p class="text-muted mb-0">Còn nợ</p>
                            </div>
                        </div>

                        <div class="mt-4">
                            <a asp-action="Invoices" asp-route-id="@apt.Id" class="btn btn-outline-primary btn-block">
                                <i class="feather icon-file-text"></i> Xem hóa đơn
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
