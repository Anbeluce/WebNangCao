@model List<WebNangCao.Models.Invoice>
@{
    ViewData["Title"] = $"Hóa đơn căn hộ {ViewBag.ApartmentNumber}";
}

<div class="row mb-3">
    <div class="col-sm-12">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-3">
            <i class="feather icon-arrow-left"></i> Quay lại tài khoản
        </a>
        <h2 class="mb-2">📄 Hóa đơn căn hộ @ViewBag.ApartmentNumber</h2>
        <p class="text-muted">Tổng cộng @Model.Count hóa đơn</p>
    </div>
</div>

@if (!Model.Any())
{
    <div class="row">
        <div class="col-12">
            <div class="card text-center">
                <div class="card-body py-5">
                    <i class="feather icon-file-text display-3 text-muted mb-3 d-block"></i>
                    <h5 class="text-muted">Chưa có hóa đơn nào cho căn hộ này.</h5>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="row">
        @foreach (var inv in Model)
        {
            var sBgClass = inv.Status == WebNangCao.Models.InvoiceStatus.Paid ? "badge-success" : inv.Status == WebNangCao.Models.InvoiceStatus.Partial ? "badge-warning text-dark" : "badge-danger";
            var sTxt = inv.Status == WebNangCao.Models.InvoiceStatus.Paid ? "Đã thanh toán" : inv.Status == WebNangCao.Models.InvoiceStatus.Partial ? "Một phần" : "Chưa thanh toán";

            <div class="col-sm-12">
                <div class="card mb-3">
                    <div class="card-body p-3">
                        <div class="row align-items-center">
                            <!-- Tháng/Năm & Hạn -->
                            <div class="col-md-3 col-sm-6 mb-2 mb-md-0 d-flex align-items-center">
                                <div class="bg-primary text-white d-inline-flex flex-column align-items-center justify-content-center rounded mr-3" style="width: 50px; height: 50px;">
                                    <span class="f-16 font-weight-bold">@inv.Month</span>
                                    <span class="f-10">@inv.Year</span>
                                </div>
                                <div>
                                    <h6 class="mb-1">Tháng @inv.Month/@inv.Year</h6>
                                    <small class="text-muted">Hạn: @inv.DueDate.ToString("dd/MM/yyyy")</small>
                                </div>
                            </div>
                            
                            <!-- Chi tiết nước, DV -->
                            <div class="col-md-5 col-sm-6 mb-2 mb-md-0">
                                <div class="row text-center">
                                    <div class="col-6 border-right">
                                        <small class="text-muted d-block">💧 Nước (@inv.WaterUsage m³)</small>
                                        <span class="font-weight-bold text-info">@inv.WaterFee.ToString("N0")đ</span>
                                    </div>
                                    <div class="col-6">
                                        <small class="text-muted d-block">🏢 Phí dịch vụ</small>
                                        <span class="font-weight-bold text-primary">@inv.ServiceFee.ToString("N0")đ</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Tổng tiền & Trạng thái -->
                            <div class="col-md-4 col-sm-12 text-md-right text-center d-flex align-items-center justify-content-md-end justify-content-between">
                                <div class="mr-3 text-left text-md-right">
                                    <small class="text-muted d-block">Tổng cộng</small>
                                    <h5 class="mb-0">@inv.TotalAmount.ToString("N0")đ</h5>
                                </div>
                                <div class="mr-3">
                                    <span class="badge @sBgClass px-3 py-2 font-weight-bold" style="border-radius: 6px;">@sTxt</span>
                                </div>
                                <div>
                                    <a asp-action="InvoiceDetail" asp-route-id="@inv.Id" class="btn btn-outline-secondary btn-sm">Chi tiết <i class="feather icon-arrow-right"></i></a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
