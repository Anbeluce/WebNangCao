@model List<WebNangCao.Models.Invoice>
@{
    ViewData["Title"] = $"Hóa đơn căn hộ {ViewBag.ApartmentNumber}";
}

<div style="margin-bottom:20px;">
    <a asp-action="Index" style="color:rgba(255,255,255,0.5); text-decoration:none; font-size:13px;">← Quay lại tài khoản</a>
</div>

<div style="margin-bottom:24px;">
    <h2 style="font-size:22px; font-weight:700; color:#fff; margin:0;">📄 Hóa đơn căn hộ @ViewBag.ApartmentNumber</h2>
    <p style="font-size:13px; color:rgba(255,255,255,0.45); margin:4px 0 0;">Tổng cộng @Model.Count hóa đơn</p>
</div>

@if (!Model.Any())
{
    <div style="background:var(--card-bg, #1a1d27); border:1px solid rgba(255,255,255,0.08); border-radius:14px; padding:40px; text-align:center;">
        <div style="font-size:48px; margin-bottom:12px;">📄</div>
        <p style="color:rgba(255,255,255,0.5);">Chưa có hóa đơn nào cho căn hộ này.</p>
    </div>
}
else
{
    <div style="display:flex; flex-direction:column; gap:12px;">
        @foreach (var inv in Model)
        {
            var sColor = inv.Status == WebNangCao.Models.InvoiceStatus.Paid ? "#4ade80" : inv.Status == WebNangCao.Models.InvoiceStatus.Partial ? "#fbbf24" : "#f87171";
            var sBg = inv.Status == WebNangCao.Models.InvoiceStatus.Paid ? "rgba(74,222,128,0.12)" : inv.Status == WebNangCao.Models.InvoiceStatus.Partial ? "rgba(251,191,36,0.12)" : "rgba(248,113,113,0.12)";
            var sTxt = inv.Status == WebNangCao.Models.InvoiceStatus.Paid ? "Đã thanh toán" : inv.Status == WebNangCao.Models.InvoiceStatus.Partial ? "Một phần" : "Chưa thanh toán";

            <div style="background:var(--card-bg, #1a1d27); border:1px solid rgba(255,255,255,0.08); border-radius:14px; padding:20px; transition:border-color 0.2s;"
                 onmouseover="this.style.borderColor='rgba(102,126,234,0.3)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)'">
                <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:12px;">
                    <div style="display:flex; align-items:center; gap:14px;">
                        <div style="background:linear-gradient(135deg,#667eea,#764ba2); width:46px; height:46px; border-radius:12px; display:flex; flex-direction:column; align-items:center; justify-content:center;">
                            <div style="font-size:14px; font-weight:700; color:#fff; line-height:1;">@inv.Month</div>
                            <div style="font-size:9px; color:rgba(255,255,255,0.7);">@inv.Year</div>
                        </div>
                        <div>
                            <div style="font-size:15px; font-weight:600; color:#fff;">Tháng @inv.Month/@inv.Year</div>
                            <div style="font-size:12px; color:rgba(255,255,255,0.4);">Hạn: @inv.DueDate.ToString("dd/MM/yyyy")</div>
                        </div>
                    </div>
                    <div style="display:flex; gap:20px; font-size:13px;">
                        <div style="text-align:center;">
                            <div style="color:rgba(255,255,255,0.4); font-size:11px;">⚡ Điện (@inv.ElectricityUsage kWh)</div>
                            <div style="color:#fbbf24; font-weight:600;">@inv.ElectricityFee.ToString("N0")đ</div>
                        </div>
                        <div style="text-align:center;">
                            <div style="color:rgba(255,255,255,0.4); font-size:11px;">💧 Nước (@inv.WaterUsage m³)</div>
                            <div style="color:#60a5fa; font-weight:600;">@inv.WaterFee.ToString("N0")đ</div>
                        </div>
                        <div style="text-align:center;">
                            <div style="color:rgba(255,255,255,0.4); font-size:11px;">🏢 Phí DV</div>
                            <div style="color:#a78bfa; font-weight:600;">@inv.ServiceFee.ToString("N0")đ</div>
                        </div>
                    </div>
                    <div style="display:flex; align-items:center; gap:16px;">
                        <div style="text-align:right;">
                            <div style="font-size:11px; color:rgba(255,255,255,0.4);">Tổng cộng</div>
                            <div style="font-size:18px; font-weight:700; color:#fff;">@inv.TotalAmount.ToString("N0")đ</div>
                        </div>
                        <span style="padding:5px 12px; background:@sBg; color:@sColor; border-radius:20px; font-size:12px; font-weight:600;">@sTxt</span>
                        <a asp-action="InvoiceDetail" asp-route-id="@inv.Id" style="padding:7px 14px; background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.1); border-radius:8px; color:rgba(255,255,255,0.7); text-decoration:none; font-size:12px;">Chi tiết →</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
