@model WebNangCao.Models.Invoice
@inject WebNangCao.Services.ISepayService SepayService
@{
    ViewData["Title"] = $"Chi tiết hóa đơn T{Model.Month}/{Model.Year}";
}

<div class="row mb-3">
    <div class="col-sm-12">
        <a asp-action="Invoices" asp-route-id="@Model.ApartmentId" class="btn btn-outline-secondary btn-sm mb-3">
            <i class="feather icon-arrow-left"></i> Quay lại danh sách hóa đơn
        </a>
    </div>
</div>

@{
    var sColorClass = Model.Status == WebNangCao.Models.InvoiceStatus.Paid ? "text-success" : Model.Status == WebNangCao.Models.InvoiceStatus.Partial ? "text-warning" : "text-danger";
    var sBgClass = Model.Status == WebNangCao.Models.InvoiceStatus.Paid ? "badge-light-success" : Model.Status == WebNangCao.Models.InvoiceStatus.Partial ? "badge-light-warning" : "badge-light-danger";
    var sTxt = Model.Status == WebNangCao.Models.InvoiceStatus.Paid ? "✅ Đã thanh toán" : Model.Status == WebNangCao.Models.InvoiceStatus.Partial ? "⏳ Một phần" : "❌ Chưa thanh toán";
    var paidAmount = Model.Transactions.Where(t => !t.IsDeleted).Sum(t => t.Amount);
    var remaining = Model.TotalAmount - paidAmount;
}

@if (TempData["SuccessMessage"] != null)
{
<div class="alert alert-success alert-dismissible fade show" role="alert">
    @TempData["SuccessMessage"]
    <button type="button" class="close" data-dismiss="alert" aria-label="Close">
        <span aria-hidden="true">&times;</span>
    </button>
</div>
}

<div class="row">
    <!-- Cột trái: Chi tiết hóa đơn -->
    <div class="col-xl-8 col-md-12">
        <!-- Header Hóa đơn -->
        <div class="card mb-4">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-sm-8">
                        <h4 class="mb-1">Hóa đơn tháng @Model.Month/@Model.Year</h4>
                        <p class="text-muted mb-0">Căn hộ @(Model.Apartment?.ApartmentNumber ?? "") • Tầng @(Model.Apartment?.Floor ?? 0)</p>
                    </div>
                    <div class="col-sm-4 text-sm-right mt-3 mt-sm-0">
                        <span class="badge @sBgClass f-14 py-2 px-3">@sTxt</span>
                    </div>
                </div>
                <hr>
                <div class="row">
                    <div class="col-12">
                        <span class="text-muted">Hạn thanh toán: </span>
                        <strong class="text-body">@Model.DueDate.ToString("dd/MM/yyyy")</strong>
                        @if (Model.DueDate < DateTime.UtcNow.AddHours(7) && Model.Status != WebNangCao.Models.InvoiceStatus.Paid)
                        {
                        <span class="text-danger ml-2"><i class="feather icon-alert-circle"></i> Đã quá hạn</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Chi tiết phí -->
        <div class="card">
            <div class="card-header">
                <h5>Chi tiết phí</h5>
            </div>
            <div class="card-body">
                <ul class="list-group list-group-flush">

                    <!-- Nước -->
                    <li class="list-group-item px-0 py-3">
                        <div class="row align-items-center">
                            <div class="col-auto">
                                <div class="bg-light-primary text-primary d-inline-flex align-items-center justify-content-center rounded" style="width: 40px; height: 40px; font-size: 20px;">
                                    💧
                                </div>
                            </div>
                            <div class="col">
                                <h6 class="mb-1">Tiền nước</h6>
                                <small class="text-muted">@Model.WaterUsage m³ × @Model.WaterUnitPrice.ToString("N0")đ/m³</small>
                            </div>
                            <div class="col-auto text-right">
                                <h6 class="mb-0 text-primary">@Model.WaterFee.ToString("N0")đ</h6>
                            </div>
                        </div>
                    </li>
                    <!-- Phí quản lý vận hành -->
                    <li class="list-group-item px-0 py-3">
                        <div class="row align-items-center">
                            <div class="col-auto">
                                <div class="bg-light-info text-info d-inline-flex align-items-center justify-content-center rounded" style="width: 40px; height: 40px; font-size: 20px;">
                                    🏢
                                </div>
                            </div>
                            <div class="col">
                                <h6 class="mb-1">Phí quản lý vận hành</h6>
                                <small class="text-muted">Diện tích: @(Model.Apartment?.Area ?? 0) m² × @((Model.Apartment != null && Model.Apartment.Area > 0 ? (Model.ManagementFee / (decimal)Model.Apartment.Area) : 0).ToString("N0"))đ/m²</small>
                            </div>
                            <div class="col-auto text-right">
                                <h6 class="mb-0 text-info">@Model.ManagementFee.ToString("N0")đ</h6>
                            </div>
                        </div>
                    </li>
                    <!-- Phí vệ sinh -->
                    <li class="list-group-item px-0 py-3">
                        <div class="row align-items-center">
                            <div class="col-auto">
                                <div class="bg-light-warning text-warning d-inline-flex align-items-center justify-content-center rounded" style="width: 40px; height: 40px; font-size: 20px;">
                                    🧹
                                </div>
                            </div>
                            <div class="col">
                                <h6 class="mb-1">Phí vệ sinh & rác thải</h6>
                                <small class="text-muted">Phí cố định theo căn hộ</small>
                            </div>
                            <div class="col-auto text-right">
                                <h6 class="mb-0 text-warning">@Model.WasteFee.ToString("N0")đ</h6>
                            </div>
                        </div>
                    </li>
                    <!-- Phí gửi xe -->
                    <li class="list-group-item px-0 py-3 border-bottom-0">
                        <div class="row align-items-center">
                            <div class="col-auto">
                                <div class="bg-light-success text-success d-inline-flex align-items-center justify-content-center rounded" style="width: 40px; height: 40px; font-size: 20px;">
                                    🏍️
                                </div>
                            </div>
                            <div class="col">
                                <h6 class="mb-1">Phí gửi xe</h6>
                                <small class="text-muted">Phí cố định theo căn hộ</small>
                            </div>
                            <div class="col-auto text-right">
                                <h6 class="mb-0 text-success">@Model.ParkingFee.ToString("N0")đ</h6>
                            </div>
                        </div>
                    </li>
                </ul>

                <hr class="mt-0">

                <div class="row align-items-center mb-2">
                    <div class="col">
                        <h6 class="mb-0 text-muted">Tổng cộng</h6>
                    </div>
                    <div class="col-auto">
                        <h4 class="mb-0">@Model.TotalAmount.ToString("N0")đ</h4>
                    </div>
                </div>

                @if (paidAmount > 0)
                {
                <div class="row align-items-center mt-2">
                    <div class="col">
                        <span class="text-muted">Đã thanh toán</span>
                    </div>
                    <div class="col-auto">
                        <h6 class="mb-0 text-success">@paidAmount.ToString("N0")đ</h6>
                    </div>
                </div>
                }

                @if (remaining > 0)
                {
                <div class="row align-items-center mt-2">
                    <div class="col">
                        <span class="text-muted">Còn lại</span>
                    </div>
                    <div class="col-auto">
                        <h6 class="mb-0 text-danger">@remaining.ToString("N0")đ</h6>
                    </div>
                </div>
                }
            </div>
        </div>
    </div>

    @{
    // Nội dung chuyển khoản: HD <Số hóa đơn>
    var paymentDescription = $"HD{Model.Id}";

    // Chỉ hiện mã QR nếu hóa đơn chưa thanh toán xong
    var showQR = Model.Status != WebNangCao.Models.InvoiceStatus.Paid && remaining > 0;
    var qrUrl = showQR ? SepayService.GenerateQrUrl(remaining, paymentDescription) : "";
    }

    <!-- Cột phải: Lịch sử thanh toán -->
<div class="col-xl-4 col-md-12">
    @if (showQR)
        {
    <div class="card mb-4 border-0 shadow-sm" style="border-radius: 15px; overflow: hidden;">
        <div class="card-header border-0 pb-0 text-center bg-white mt-3">
            <h5 class="mb-1 font-weight-bold text-primary"><i class="feather icon-maximize"></i> Quét mã để thanh toán</h5>
            <p class="small text-muted mb-0">Sử dụng ứng dụng Ngân hàng hoặc Ví điện tử</p>
        </div>
        <div class="card-body text-center pt-3">
            <div class="p-3 rounded mb-3 d-inline-block" style="border: 2px dashed #007bff; background-color: #f8f9fa;">
                <img src="@qrUrl"
                     class="img-fluid"
                     alt="Mã QR SePay"
                     style="width: 100%; max-width: 250px; border-radius: 10px;" />
            </div>

            <div class="text-left bg-light p-3 rounded mb-3 border">
                <div class="d-flex justify-content-between mb-2 pb-2 border-bottom">
                    <span class="text-muted">Số tiền cần thanh toán:</span>
                    <span class="font-weight-bold text-danger h6 mb-0">@remaining.ToString("N0") VNĐ</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="text-muted">Nội dung chuyển khoản:</span>
                    <span class="font-weight-bold text-primary">@paymentDescription</span>
                </div>
            </div>
            
            <div class="alert alert-info py-2 small text-left mb-3">
                <i class="feather icon-info mr-1"></i> Giao dịch sẽ được hệ thống cập nhật tự động trong vòng 1-3 phút. Xin vui lòng không tắt trang này.
            </div>

            <div class="d-flex justify-content-center align-items-center mt-2 mb-2" id="payment-loader">
                <div class="spinner-border spinner-border-sm text-primary mr-2" role="status">
                    <span class="sr-only">Đang chờ...</span>
                </div>
                <span class="text-primary font-weight-bold">Đang chờ thanh toán...</span>
            </div>
            
            <button class="btn btn-outline-secondary btn-block mt-3" onclick="window.print()">
                <i class="feather icon-printer"></i> In thông báo đóng phí
            </button>
        </div>
    </div>
        }
    @if (Model.Transactions.Any(t => !t.IsDeleted))
        {
    <div class="card">
        <div class="card-header">
            <h5>💳 Lịch sử thanh toán</h5>
        </div>
        <div class="card-body p-0">
            <ul class="list-group list-group-flush">
                @foreach (var tx in Model.Transactions.Where(t => !t.IsDeleted).OrderByDescending(t => t.PaymentDate))
                        {
                <li class="list-group-item">
                    <div class="row align-items-center">
                        <div class="col">
                            <h6 class="mb-1">@tx.PaymentMethod</h6>
                            <small class="text-muted"><i class="feather icon-calendar"></i> @tx.PaymentDate.ToString("dd/MM/yyyy HH:mm")</small>
                            @if (!string.IsNullOrEmpty(tx.Note))
                                        {
                            <small class="d-block text-muted mt-1">📝 @tx.Note</small>
                                        }
                        </div>
                        <div class="col-auto text-right">
                            <h6 class="mb-0 text-success">+@tx.Amount.ToString("N0")đ</h6>
                        </div>
                    </div>
                </li>
                        }
            </ul>
        </div>
    </div>
        }
</div>
</div>

@section Scripts {
    @if (showQR)
    {
        <script>
            $(document).ready(function () {
                var invoiceId = @Model.Id;
                var currentPaidAmount = parseFloat("@paidAmount.ToString(System.Globalization.CultureInfo.InvariantCulture)");

                var pollInterval = setInterval(function () {
                    // Thêm tham số t để chống cache trên trình duyệt
                    $.get('/Resident/CheckPaymentStatus/' + invoiceId + '?t=' + new Date().getTime(), function (data) {
                        console.log("Checking payment:", data);
                        if (data && data.totalPaid > currentPaidAmount) {
                            clearInterval(pollInterval);
                            Swal.fire({
                                icon: 'success',
                                title: 'Thanh toán thành công!',
                                text: 'Hệ thống sẽ tự động cập nhật trong giây lát...',
                                timer: 2000,
                                showConfirmButton: false
                            }).then(() => {
                                window.location.reload();
                            });
                        }
                    });
                }, 5000); // Poll every 5 seconds
            });
        </script>
    }
}
