@model WebNangCao.Models.ViewModels.ProfileVM
@{
    ViewData["Title"] = "Tài khoản của tôi";
}

<div class="row">
    <!-- Cột trái: Thông tin tổng quan và Đổi mật khẩu -->
    <div class="col-xl-4 col-md-5">
        <!-- Card Thông tin ngắn gọn -->
        <div class="card user-card user-card-1">
            <div class="card-body pt-0">
                <div class="user-about-block text-center mt-4">
                    <div class="row align-items-end">
                        <div class="col text-center">
                            <div style="width:80px; height:80px; background:linear-gradient(135deg,#667eea,#764ba2); border-radius:50%; display:inline-flex; align-items:center; justify-content:center; font-size:36px; color:#fff;">
                                👤
                            </div>
                        </div>
                    </div>
                </div>
                <div class="text-center">
                    <h4 class="mb-1 mt-3">@Model.FullName</h4>
                    <p class="mb-3 text-muted">@Model.Email</p>
                </div>
                
                <hr>

                <div class="row text-center mt-3">
                    <div class="col-6 mb-3">
                        <h6 class="mb-1">@Model.ApartmentCount</h6>
                        <p class="text-muted mb-0">Căn hộ</p>
                    </div>
                    <div class="col-6 mb-3">
                        <h6 class="mb-1">@Model.InvoiceCount</h6>
                        <p class="text-muted mb-0">Hóa đơn</p>
                    </div>
                    <div class="col-6">
                        <h6 class="mb-1 text-danger">@Model.UnpaidInvoiceCount</h6>
                        <p class="text-muted mb-0">Chưa thanh toán</p>
                    </div>
                    <div class="col-6">
                        <h6 class="mb-1 text-warning">@Model.TotalDebt.ToString("N0") đ</h6>
                        <p class="text-muted mb-0">Còn nợ</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Card Đổi mật khẩu -->
        <div class="card">
            <div class="card-header">
                <h5>Đổi mật khẩu</h5>
            </div>
            <div class="card-body">
                @if (TempData["ShowPasswordForm"] != null && TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                }

                <form asp-action="ChangePassword" method="post">
                    @Html.AntiForgeryToken()
                    <div class="form-group">
                        <label asp-for="ChangePassword.CurrentPassword"></label>
                        <input asp-for="ChangePassword.CurrentPassword" class="form-control" />
                        <span asp-validation-for="ChangePassword.CurrentPassword" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="ChangePassword.NewPassword"></label>
                        <input asp-for="ChangePassword.NewPassword" class="form-control" />
                        <span asp-validation-for="ChangePassword.NewPassword" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="ChangePassword.ConfirmPassword"></label>
                        <input asp-for="ChangePassword.ConfirmPassword" class="form-control" />
                        <span asp-validation-for="ChangePassword.ConfirmPassword" class="text-danger"></span>
                    </div>
                    <button type="submit" class="btn btn-warning btn-block">
                        <i class="feather icon-lock"></i> Đổi mật khẩu
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Cột phải: Form cập nhật thông tin cá nhân -->
    <div class="col-xl-8 col-md-7">
        <div class="card">
            <div class="card-header">
                <h5>Cập nhật thông tin cá nhân</h5>
            </div>
            <div class="card-body">
                <form asp-action="UpdateProfile" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="FullName"></label>
                                <input asp-for="FullName" class="form-control" />
                                <span asp-validation-for="FullName" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Email</label>
                                <input value="@Model.Email" disabled class="form-control" />
                                <small class="form-text text-muted">Email dùng để đăng nhập không thể thay đổi.</small>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="PhoneNumber"></label>
                                <input asp-for="PhoneNumber" class="form-control" placeholder="VD: 0912345678" />
                                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="IdentityCardNumber"></label>
                                <input asp-for="IdentityCardNumber" class="form-control" placeholder="VD: 012345678901" />
                                <span asp-validation-for="IdentityCardNumber" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="DateOfBirth"></label>
                                <input asp-for="DateOfBirth" type="date" class="form-control" />
                            </div>
                        </div>
                    </div>

                    <hr>
                    <button type="submit" class="btn btn-primary">
                        <i class="feather icon-save"></i> Lưu thay đổi
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
