@model WebNangCao.Models.ViewModels.Auth.RegisterVM
@{
    ViewData["Title"] = "Đăng ký";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng ký - Hệ thống Quản lý Chung cư</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
            padding: 20px;
        }

        .auth-wrapper {
            width: 100%;
            max-width: 520px;
        }

        .auth-card {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px;
            padding: 48px 40px;
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.4);
        }

        .auth-logo {
            text-align: center;
            margin-bottom: 32px;
        }

        .auth-logo .logo-icon {
            width: 64px;
            height: 64px;
            background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
            border-radius: 16px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            margin-bottom: 16px;
            box-shadow: 0 8px 24px rgba(17, 153, 142, 0.4);
        }

        .auth-logo h1 {
            color: #fff;
            font-size: 22px;
            font-weight: 700;
            letter-spacing: -0.5px;
        }

        .auth-logo p {
            color: rgba(255,255,255,0.5);
            font-size: 13px;
            margin-top: 4px;
        }

        .form-label {
            color: rgba(255,255,255,0.8);
            font-size: 13px;
            font-weight: 500;
            margin-bottom: 8px;
        }

        .form-control {
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 12px;
            color: #fff;
            padding: 12px 16px;
            font-size: 14px;
            transition: all 0.3s ease;
        }

        .form-control:focus {
            background: rgba(255,255,255,0.12);
            border-color: #11998e;
            box-shadow: 0 0 0 3px rgba(17, 153, 142, 0.2);
            color: #fff;
        }

        .form-control::placeholder { color: rgba(255,255,255,0.3); }

        .btn-register {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
            border: none;
            border-radius: 12px;
            color: #fff;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            letter-spacing: 0.3px;
            box-shadow: 0 4px 15px rgba(17, 153, 142, 0.4);
        }

        .btn-register:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 25px rgba(17, 153, 142, 0.5);
            color: #fff;
        }

        .auth-footer {
            text-align: center;
            margin-top: 24px;
        }

        .auth-footer p {
            color: rgba(255,255,255,0.5);
            font-size: 13px;
        }

        .auth-footer a {
            color: #38ef7d;
            text-decoration: none;
            font-weight: 600;
        }

        .auth-footer a:hover { color: #11998e; text-decoration: underline; }

        .field-validation-error {
            color: #fca5a5;
            font-size: 12px;
            margin-top: 4px;
            display: block;
        }

        .alert-danger {
            background: rgba(239, 68, 68, 0.15);
            border: 1px solid rgba(239, 68, 68, 0.3);
            color: #fca5a5;
            border-radius: 12px;
            padding: 12px 16px;
            font-size: 13px;
        }

        .section-divider {
            color: rgba(255,255,255,0.4);
            font-size: 12px;
            font-weight: 600;
            letter-spacing: 1px;
            text-transform: uppercase;
            margin: 20px 0 16px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .section-divider::before, .section-divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: rgba(255,255,255,0.1);
        }

        .password-hint {
            color: rgba(255,255,255,0.35);
            font-size: 11px;
            margin-top: 5px;
        }
    </style>
</head>
<body>
    <div class="auth-wrapper">
        <div class="auth-card">
            <div class="auth-logo">
                <div class="logo-icon">✨</div>
                <h1>Tạo tài khoản</h1>
                <p>Điền thông tin để đăng ký tài khoản cư dân</p>
            </div>

            <div asp-validation-summary="ModelOnly" class="alert-danger mb-3"></div>

            <form asp-action="Register" asp-controller="Auth" method="post">
                @Html.AntiForgeryToken()

                <div class="section-divider">Thông tin cá nhân</div>

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label">👤 Họ và tên *</label>
                    <input asp-for="FullName" class="form-control" placeholder="Nguyễn Văn A" id="regFullName" />
                    <span asp-validation-for="FullName" class="field-validation-error"></span>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="PhoneNumber" class="form-label">📞 Số điện thoại</label>
                        <input asp-for="PhoneNumber" class="form-control" placeholder="0901234567" id="regPhone" />
                        <span asp-validation-for="PhoneNumber" class="field-validation-error"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="DateOfBirth" class="form-label">🎂 Ngày sinh</label>
                        <input asp-for="DateOfBirth" class="form-control" type="date" id="regDob" />
                        <span asp-validation-for="DateOfBirth" class="field-validation-error"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="IdentityCardNumber" class="form-label">🪪 Số CCCD/CMND</label>
                    <input asp-for="IdentityCardNumber" class="form-control" placeholder="001234567890" id="regCccd" />
                    <span asp-validation-for="IdentityCardNumber" class="field-validation-error"></span>
                </div>

                <div class="section-divider">Thông tin đăng nhập</div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">📧 Email *</label>
                    <input asp-for="Email" class="form-control" placeholder="email@example.com" autocomplete="email" id="regEmail" />
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label asp-for="Password" class="form-label">🔒 Mật khẩu *</label>
                        <input asp-for="Password" class="form-control" placeholder="••••••••" autocomplete="new-password" id="regPassword" required />
                        <span class="password-hint">Ít nhất 6 ký tự, có chữ hoa và số</span>
                        <span asp-validation-for="Password" class="field-validation-error"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="ConfirmPassword" class="form-label">🔒 Xác nhận *</label>
                        <input asp-for="ConfirmPassword" class="form-control" placeholder="••••••••" autocomplete="new-password" id="regConfirmPassword" required />
                        <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
                    </div>
                </div>

                <button type="submit" class="btn-register" id="registerBtn">
                    Tạo tài khoản
                </button>
            </form>

            <div class="auth-footer">
                <p>Đã có tài khoản? <a asp-action="Login" asp-controller="Auth">Đăng nhập</a></p>
            </div>
        </div>

        <div style="text-align:center;margin-top:20px;">
            <p style="color:rgba(255,255,255,0.3);font-size:12px;">
                © 2026 Chung cư Smart. Mọi quyền được bảo lưu.
            </p>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
