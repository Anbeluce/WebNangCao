@model WebNangCao.Models.ViewModels.Auth.RegisterVM
@{
    ViewData["Title"] = "Đăng ký";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">

<head>
    <title>Đăng ký - Chung cư Smart</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=0, minimal-ui">
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <!-- Favicon icon -->
    <link rel="icon" href="~/images/favicon.ico" type="image/x-icon">
    <!-- fontawesome icon -->
    <link rel="stylesheet" href="~/fonts/fontawesome/css/fontawesome-all.min.css">
    <!-- animation css -->
    <link rel="stylesheet" href="~/plugins/animation/css/animate.min.css">
    <!-- vendor css -->
    <link rel="stylesheet" href="~/css/style.css">
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body { font-family: 'Inter', sans-serif !important; }
        .field-validation-error { color: #dc3545; font-size: 80%; display: block; text-align: left; margin-bottom: 10px; margin-top: -5px; }
        .input-validation-error { border-color: #dc3545; }
        .auth-content { max-width: 500px; margin: 0 auto; }
    </style>
</head>

<body>
    <!-- [ auth-signup ] start -->
    <div class="auth-wrapper">
        <div class="auth-content">
            <div class="card">
                <div class="row align-items-center justify-content-center">
                    <div class="col-md-12">
                        <div class="card-body">
                            <!-- Header -->
                            <div class="text-center mb-4">
                                <div class="bg-primary text-white d-inline-flex align-items-center justify-content-center rounded" style="width: 50px; height: 50px; font-size: 24px; margin-bottom: 15px;">
                                    <i class="feather icon-user-plus"></i>
                                </div>
                                <h4 class="mb-3 f-w-400">Tạo tài khoản mới</h4>
                                <p class="text-muted">Hệ thống quản lý Chung cư Smart</p>
                            </div>

                            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                            {
                                <div class="alert alert-danger text-left">
                                    Vui lòng kiểm tra lại các thông tin bên dưới.
                                </div>
                            }

                            <!-- Form -->
                            <form asp-action="Register" asp-controller="Auth" method="post">
                                @Html.AntiForgeryToken()
                                
                                <div class="input-group mb-3">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text"><i class="feather icon-user"></i></span>
                                    </div>
                                    <input asp-for="FullName" class="form-control" placeholder="Họ và tên *">
                                </div>
                                <span asp-validation-for="FullName"></span>

                                <div class="input-group mb-3">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text"><i class="feather icon-mail"></i></span>
                                    </div>
                                    <input asp-for="Email" class="form-control" placeholder="Địa chỉ Email *">
                                </div>
                                <span asp-validation-for="Email"></span>

                                <div class="input-group mb-3">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text"><i class="feather icon-phone"></i></span>
                                    </div>
                                    <input asp-for="PhoneNumber" class="form-control" placeholder="Số điện thoại">
                                </div>
                                <span asp-validation-for="PhoneNumber"></span>

                                <div class="row">
                                    <div class="col-sm-6">
                                        <div class="input-group mb-3">
                                            <div class="input-group-prepend">
                                                <span class="input-group-text"><i class="feather icon-credit-card"></i></span>
                                            </div>
                                            <input asp-for="IdentityCardNumber" class="form-control" placeholder="Số CCCD">
                                        </div>
                                        <span asp-validation-for="IdentityCardNumber"></span>
                                    </div>
                                    <div class="col-sm-6">
                                        <div class="input-group mb-3">
                                            <div class="input-group-prepend">
                                                <span class="input-group-text"><i class="feather icon-calendar"></i></span>
                                            </div>
                                            <input asp-for="DateOfBirth" type="date" class="form-control">
                                        </div>
                                        <span asp-validation-for="DateOfBirth"></span>
                                    </div>
                                </div>

                                <div class="input-group mb-3">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text"><i class="feather icon-lock"></i></span>
                                    </div>
                                    <input asp-for="Password" class="form-control" placeholder="Mật khẩu *">
                                </div>
                                <span asp-validation-for="Password"></span>

                                <div class="input-group mb-4">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text"><i class="feather icon-shield"></i></span>
                                    </div>
                                    <input asp-for="ConfirmPassword" class="form-control" placeholder="Xác nhận mật khẩu *">
                                </div>
                                <span asp-validation-for="ConfirmPassword"></span>

                                <button type="submit" class="btn btn-primary btn-block mb-4">Đăng ký</button>
                            </form>

                            <p class="mb-2 text-muted">Đã có tài khoản? <a asp-action="Login" class="f-w-400">Đăng nhập</a></p>
                            <div class="mt-4 text-center">
                                <a asp-action="Index" asp-controller="Home" class="text-muted"><i class="feather icon-home"></i> Trở về Trang chủ</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- [ auth-signup ] end -->

    <!-- Required Js -->
    <script src="~/js/vendor-all.min.js"></script>
    <script src="~/plugins/bootstrap/js/bootstrap.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>

</html>
