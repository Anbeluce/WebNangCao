@{
    ViewData["Title"] = "Truy cập bị từ chối";
}

@section Styles {
    <style>
        .bg-light-danger {
            background-color: #fff2f4 !important;
            color: #ff5252 !important;
        }
        .access-denied-card {
            border-radius: 16px !important;
            border: none !important;
            transition: all 0.3s ease;
        }
        .access-denied-card:hover {
            transform: translateY(-5px);
        }
    </style>
}

<div class="row justify-content-center align-items-center" style="min-height: calc(100vh - 250px);">
    <div class="col-sm-12 col-md-8 col-lg-6 col-xl-5">
        <div class="card access-denied-card shadow-sm">
            <div class="card-body text-center p-5">
                <div class="mb-4">
                    <span class="d-inline-flex align-items-center justify-content-center bg-light-danger rounded-circle" style="width: 90px; height: 90px; box-shadow: 0 10px 20px rgba(255, 82, 82, 0.15);">
                        <i class="feather icon-shield" style="font-size: 45px;"></i>
                    </span>
                </div>
                
                <h2 class="font-weight-bold text-dark mb-3">Truy cập bị từ chối</h2>
                <div class="w-100 mb-4 px-3 py-2 bg-light rounded text-muted small" style="border-left: 4px solid #ff5252; background-color: #f8f9fa;">
                    Mã lỗi: <strong>403 Forbidden</strong> — Quyền truy cập bị hạn chế.
                </div>
                
                <p class="text-muted mb-5 font-weight-normal px-2">
                    Tài khoản của bạn không có đủ quyền hạn để truy cập trang này. Vui lòng đăng nhập bằng tài khoản Quản trị viên (Admin) hoặc liên hệ Ban quản lý nếu bạn cho rằng đây là sự cố.
                </p>
                
                <div class="d-flex flex-column flex-sm-row justify-content-center align-items-center gap-2">
                    <a href="/" class="btn btn-primary px-4 py-2 font-weight-bold shadow-sm mb-2 mb-sm-0" style="border-radius: 8px;">
                        <i class="feather icon-home mr-1"></i> Quay về Trang chủ
                    </a>
                    
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a href="javascript:document.getElementById('logoutFormAccessDenied').submit();" class="btn btn-outline-danger px-4 py-2 font-weight-bold ml-0 ml-sm-2" style="border-radius: 8px;">
                            <i class="feather icon-log-out mr-1"></i> Đăng xuất
                        </a>
                        <form asp-action="Logout" asp-controller="Auth" asp-area="" method="post" id="logoutFormAccessDenied" style="display:none;">
                            @Html.AntiForgeryToken()
                        </form>
                    }
                    else
                    {
                        <a asp-action="Login" asp-controller="Auth" asp-area="" class="btn btn-outline-primary px-4 py-2 font-weight-bold ml-0 ml-sm-2" style="border-radius: 8px;">
                            <i class="feather icon-log-in mr-1"></i> Đăng nhập
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
