@model WebNangCao.Models.ViewModels.Auth.LoginVM
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">

<head>
    <title>Đăng nhập - Chung cư Smart</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=0, minimal-ui">
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <!-- Favicon icon -->
    <link rel="icon" href="~/images/favicon.ico" type="image/x-icon">
    <!-- fontawesome icon -->
    <link rel="stylesheet" href="~/fonts/fontawesome/css/fontawesome-all.min.css">
    <!-- animation css -->
    <link rel="stylesheet" href="~/plugins/animation/css/animate.min.css">
    <!-- vendor css -->
    <link rel="stylesheet" href="~/css/style.css">
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body { font-family: 'Inter', sans-serif !important; }
        .field-validation-error { color: #dc3545; font-size: 80%; display: block; text-align: left; margin-bottom: 10px; margin-top: -5px; }
        .input-validation-error { border-color: #dc3545; }
        .auth-content { max-width: 450px; margin: 0 auto; }
    </style>
</head>

<body>
    <!-- [ auth-signin ] start -->
    <div class="auth-wrapper">
        <div class="auth-content text-center">
            <div class="card">
                <div class="row align-items-center justify-content-center">
                    <div class="col-md-12">
                        <div class="card-body">
                            <!-- Header -->
                            <div class="mb-4">
                                <div class="bg-primary text-white d-inline-flex align-items-center justify-content-center rounded" style="width: 50px; height: 50px; font-size: 24px; margin-bottom: 15px;">
                                    <i class="feather icon-log-in"></i>
                                </div>
                                <h4 class="mb-3 f-w-400">Đăng nhập tài khoản</h4>
                                <p class="text-muted">Hệ thống quản lý Chung cư Smart</p>
                            </div>

                            @if (TempData["SuccessMessage"] != null)
                            {
                                <div class="alert alert-success text-left">
                                    <i class="feather icon-check-circle"></i> @TempData["SuccessMessage"]
                                </div>
                            }

                            @if (!ViewData.ModelState.IsValid)
                            {
                                <div class="alert alert-danger text-left">
                                    <div asp-validation-summary="ModelOnly"></div>
                                </div>
                            }

                            <!-- Form -->
                            <form asp-action="Login" asp-controller="Auth" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" asp-for="@ViewData["ReturnUrl"]" name="returnUrl" />

                                <div class="input-group mb-3">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text"><i class="feather icon-mail"></i></span>
                                    </div>
                                    <input asp-for="Email" class="form-control" placeholder="Địa chỉ Email">
                                </div>
                                <span asp-validation-for="Email"></span>

                                <div class="input-group mb-4">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text"><i class="feather icon-lock"></i></span>
                                    </div>
                                    <input asp-for="Password" class="form-control" placeholder="Mật khẩu">
                                </div>
                                <span asp-validation-for="Password"></span>

                                <div class="form-group text-left mt-2">
                                    <div class="checkbox checkbox-primary d-inline">
                                        <input type="checkbox" asp-for="RememberMe" id="checkbox-fill-1">
                                        <label for="checkbox-fill-1" class="cr">Ghi nhớ đăng nhập</label>
                                    </div>
                                </div>

                                <button type="submit" class="btn btn-primary btn-block mb-4">Đăng nhập</button>
                            </form>

                            <p class="mb-2 text-muted">Chưa có tài khoản? <a asp-action="Register" class="f-w-400">Đăng ký ngay</a></p>
                            <div class="mt-4 text-center">
                                <a asp-action="Index" asp-controller="Home" class="text-muted"><i class="feather icon-home"></i> Trở về Trang chủ</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- [ auth-signin ] end -->

    <!-- Required Js -->
    <script src="~/js/vendor-all.min.js"></script>
    <script src="~/plugins/bootstrap/js/bootstrap.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>

</html>
