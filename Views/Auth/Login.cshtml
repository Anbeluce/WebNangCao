@model WebNangCao.Models.ViewModels.Auth.LoginVM
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - Hệ thống Quản lý Chung cư</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
            padding: 20px;
        }

        .auth-wrapper {
            width: 100%;
            max-width: 440px;
        }

        .auth-card {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px;
            padding: 48px 40px;
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.4);
        }

        .auth-logo {
            text-align: center;
            margin-bottom: 32px;
        }

        .auth-logo .logo-icon {
            width: 64px;
            height: 64px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 16px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            margin-bottom: 16px;
            box-shadow: 0 8px 24px rgba(102, 126, 234, 0.4);
        }

        .auth-logo h1 {
            color: #fff;
            font-size: 22px;
            font-weight: 700;
            letter-spacing: -0.5px;
        }

        .auth-logo p {
            color: rgba(255,255,255,0.5);
            font-size: 13px;
            margin-top: 4px;
        }

        .form-label {
            color: rgba(255,255,255,0.8);
            font-size: 13px;
            font-weight: 500;
            margin-bottom: 8px;
        }

        .form-control {
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 12px;
            color: #fff;
            padding: 12px 16px;
            font-size: 14px;
            transition: all 0.3s ease;
        }

        .form-control:focus {
            background: rgba(255,255,255,0.12);
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.2);
            color: #fff;
        }

        .form-control::placeholder { color: rgba(255,255,255,0.3); }

        .form-check-input {
            background-color: rgba(255,255,255,0.1);
            border-color: rgba(255,255,255,0.3);
        }

        .form-check-input:checked {
            background-color: #667eea;
            border-color: #667eea;
        }

        .form-check-label {
            color: rgba(255,255,255,0.7);
            font-size: 13px;
        }

        .btn-login {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            border-radius: 12px;
            color: #fff;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            letter-spacing: 0.3px;
            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
        }

        .btn-login:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 25px rgba(102, 126, 234, 0.5);
            color: #fff;
        }

        .btn-login:active { transform: translateY(0); }

        .auth-footer {
            text-align: center;
            margin-top: 24px;
        }

        .auth-footer p {
            color: rgba(255,255,255,0.5);
            font-size: 13px;
        }

        .auth-footer a {
            color: #667eea;
            text-decoration: none;
            font-weight: 600;
        }

        .auth-footer a:hover { color: #a78bfa; text-decoration: underline; }

        .alert-danger {
            background: rgba(239, 68, 68, 0.15);
            border: 1px solid rgba(239, 68, 68, 0.3);
            color: #fca5a5;
            border-radius: 12px;
            padding: 12px 16px;
            font-size: 13px;
        }

        .text-field-invalid .form-control {
            border-color: rgba(239, 68, 68, 0.5);
        }

        .field-validation-error {
            color: #fca5a5;
            font-size: 12px;
            margin-top: 4px;
            display: block;
        }

        .divider {
            position: relative;
            text-align: center;
            margin: 20px 0;
        }

        .divider::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 0;
            right: 0;
            height: 1px;
            background: rgba(255,255,255,0.1);
        }

        .divider span {
            position: relative;
            background: transparent;
            padding: 0 12px;
            color: rgba(255,255,255,0.4);
            font-size: 12px;
        }

        .input-group-icon {
            position: relative;
        }

        .input-group-icon .icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(255,255,255,0.35);
            font-size: 16px;
            pointer-events: none;
        }

        .input-group-icon .form-control {
            padding-left: 40px;
        }
    </style>
</head>
<body>
    <div class="auth-wrapper">
        <div class="auth-card">
            <div class="auth-logo">
                <div class="logo-icon">🏢</div>
                <h1>Chung cư Smart</h1>
                <p>Hệ thống quản lý chung cư thông minh</p>
            </div>

            @*@if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert-danger mb-4">
                        <asp-validation-summary asp-validation-summary="ModelOnly" class="mb-0"></asp-validation-summary>
                        <div asp-validation-summary="ModelOnly"></div>
                    </div>
                }*@

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success rounded-3 mb-4" style="background:rgba(34,197,94,0.15);border:1px solid rgba(34,197,94,0.3);color:#86efac;font-size:13px;">
                    @TempData["SuccessMessage"]
                </div>
            }

            <form asp-action="Login" asp-controller="Auth" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="@ViewData["ReturnUrl"]" name="returnUrl" />

                <div asp-validation-summary="ModelOnly" class="alert-danger mb-3" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">📧 Email</label>
                    <input asp-for="Email" class="form-control" placeholder="email@example.com" autocomplete="email" id="loginEmail" />
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label">🔒 Mật khẩu</label>
                    <input asp-for="Password" class="form-control" placeholder="••••••••" autocomplete="current-password" id="loginPassword" />
                    <span asp-validation-for="Password" class="field-validation-error"></span>
                </div>

                <div class="mb-4">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="RememberMe" type="checkbox" id="rememberMe" />
                        <label class="form-check-label" for="rememberMe">Ghi nhớ đăng nhập</label>
                    </div>
                </div>

                <button type="submit" class="btn-login" id="loginBtn">
                    Đăng nhập
                </button>
            </form>

            <div class="divider">
                <span>hoặc</span>
            </div>

            <div class="auth-footer">
                <p>Chưa có tài khoản? <a asp-action="Register" asp-controller="Auth">Đăng ký ngay</a></p>
            </div>
        </div>

        <div style="text-align:center;margin-top:20px;">
            <p style="color:rgba(255,255,255,0.3);font-size:12px;">
                © 2026 Chung cư Smart. Mọi quyền được bảo lưu.
            </p>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script>
        $(document).ready(function () {
            // Tìm các thẻ có class alert-danger (lỗi) hoặc alert-success (thành công)
            // Đợi 2000ms (2 giây) sau đó làm mờ dần và ẩn đi trong 500ms (0.5 giây)
            $(".alert-danger, .alert-success").delay(2000).fadeOut(500);
        });
    </script>
</body>
</html>
